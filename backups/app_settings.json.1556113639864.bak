        },
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "Delivery Reminders LMP from App",
          "bool_expr": "doc.fields.lmp_date_8601"
        },
        {
          "name": "on_create",
          "trigger": "clear_schedule",
          "params": "ANC Reminders LMP from App, ANC Reminders LMP, ANC Reminders, Delivery Reminders LMP from App, Delivery Reminders LMP, Delivery Reminders, Postnatal Care, Postnatal Care for Facility Birth, Postnatal Care from App, Registration Followup ANC, Registration Followup ANC PNC",
          "bool_expr": ""
        }
      ],
      "validations": {},
      "messages": [
        {
          "translation_key": "messages.relay.chw_sms",
