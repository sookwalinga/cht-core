      "events": [
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "SC Exit",
          "bool_expr": "/exit/.test(doc.fields.task) && /SC/.test(doc.fields.treatment_program)"
        }
      ],
      "validations": {},
      "messages": [
        {
          "translation_key": "messages.nutrition_followup.sc_exit",
          "event_type": "report_accepted",
