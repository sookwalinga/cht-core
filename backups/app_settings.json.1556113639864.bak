          "bool_expr": "doc.fields.enrollment && doc.fields.enrollment.program && /OTP/.test(doc.fields.enrollment.program)"
        },
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "SFP",
          "bool_expr": "doc.fields.enrollment && doc.fields.enrollment.program && /SFP/.test(doc.fields.enrollment.program)"
        },
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "SC",
          "bool_expr": "doc.fields.enrollment && doc.fields.enrollment.program && /SC/.test(doc.fields.enrollment.program)"
        }
      ],
      "validations": {},
      "messages": [
        {
          "translation_key": "messages.treatment_enrollment.report_accepted.missed_visit",
          "event_type": "report_accepted",
          "recipient": "clinic",
          "bool_expr": "doc.fields.referral.admitted && /no/.test(doc.fields.referral.admitted)"
        },
        {
          "translation_key": "messages.treatment_enrollment.program.report_accepted",
          "event_type": "report_accepted",
          "recipient": "clinic",
          "bool_expr": "doc.fields.enrollment && doc.fields.enrollment.program"
        },
        {
          "translation_key": "messages.treatment_enrollment.report_accepted.false_positive",
          "event_type": "report_accepted",
          "recipient": "clinic",
          "bool_expr": "doc.fields.enrollment && doc.fields.enrollment.false_positive_confirmation && /yes/.test(doc.fields.enrollment.false_positive_confirmation)"
        },
        {
          "translation_key": "messages.treatment_enrollment.report_accepted.chronic_malnutrition",
          "event_type": "report_accepted",
          "recipient": "clinic",
          "bool_expr": "doc.fields.enrollment && doc.fields.enrollment.reasons && /chronic_malnutrition/.test(doc.fields.enrollment.reasons)"
        }
      ]
    }
  ],
