  "registrations": [
    {
      "form": "CW",
      "events": [
        {
          "name": "on_create",
          "trigger": "add_birth_date",
          "params": "weeks_since_birth",
          "bool_expr": "doc.fields.weeks_since_birth || doc.fields.weeks_since_birth === 0"
        },
        {
          "name": "on_create",
          "trigger": "add_patient",
          "params": "",
          "bool_expr": ""
        },
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "Child Health",
          "bool_expr": "doc.fields.weeks_since_birth || doc.fields.weeks_since_birth === 0"
        }
      ],
      "validations": {
        "join_responses": true,
        "list": [
          {
            "property": "patient_name",
            "rule": "lenMin(1) && lenMax(30)",
            "translation_key": "messages.c.validation.patient_name"
          },
          {
            "property": "weeks_since_birth",
            "rule": "integer && between(0,260)",
            "translation_key": "messages.c.validation.weeks_since_birth"
          }
        ]
      },
      "messages": [
        {
          "translation_key": "messages.c.report_accepted",
          "event_type": "report_accepted",
          "recipient": "reporting_unit"
        }
      ]
    },
    {
      "form": "CHILD",
      "events": [
        {
          "name": "on_create",
          "trigger": "add_birth_date",
          "params": "days_since_birth",
          "bool_expr": "doc.fields.days_since_birth || doc.fields.days_since_birth === 0"
        },
        {
          "name": "on_create",
          "trigger": "add_patient",
          "params": "",
          "bool_expr": ""
        },
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "Child Health",
          "bool_expr": "doc.fields.days_since_birth || doc.fields.days_since_birth === 0"
        }
      ],
      "validations": {},
      "messages": [
        {
          "translation_key": "messages.c.report_accepted",
          "event_type": "report_accepted",
          "recipient": "reporting_unit"
        }
      ]
    },
    {
      "form": "child_health_registration",
      "events": [
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "Child Health from App",
          "bool_expr": "doc.fields.birth_date"
        },
        {
          "name": "on_create",
          "trigger": "clear_schedule",
          "params": "Child Health, Child Health from App",
          "bool_expr": ""
        }
      ],
      "validations": {},
      "messages": [
        {
          "translation_key": "messages.relay.chw_sms",
          "event_type": "report_accepted",
          "recipient": "chw_phone"
        }
      ]
    },
    {
      "form": "G",
      "events": [
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "Nutrition Evaluation",
          "bool_expr": "doc.fields.severity && (/2/.test(doc.fields.severity) || /3/.test(doc.fields.severity))"
        }
      ],
      "validations": {
        "join_responses": true,
        "list": [
          {
            "property": "patient_id",
            "rule": "regex('^[0-9]{5,13}$')",
            "translation_key": "messages.generic.validation.patient_id"
          },
          {
            "property": "severity",
            "rule": "integer && between(1,3)",
            "translation_key": "messages.g.validation.severity"
          }
        ]
      },
      "messages": [
        {
          "translation_key": "messages.g.normal.report_accepted",
          "event_type": "report_accepted",
          "recipient": "reporting_unit",
          "bool_expr": "doc.fields.severity && /1/.test(doc.fields.severity)"
        },
        {
          "translation_key": "messages.g.severe.report_accepted",
          "event_type": "report_accepted",
          "recipient": "reporting_unit",
          "bool_expr": "doc.fields.severity && (/2/.test(doc.fields.severity) || /3/.test(doc.fields.severity))"
        },
        {
          "translation_key": "messages.generic.registration_not_found",
          "event_type": "registration_not_found",
          "recipient": "reporting_unit"
        }
      ]
    },
    {
      "form": "P",
      "events": [
        {
          "name": "on_create",
          "trigger": "add_expected_date",
          "params": "lmp_date",
          "bool_expr": "doc.fields.last_menstrual_period && /^[0-9]+$/.test(doc.fields.last_menstrual_period)"
        },
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "ANC Reminders LMP",
          "bool_expr": "doc.fields.last_menstrual_period && /^[0-9]+$/.test(doc.fields.last_menstrual_period)"
        },
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "Delivery Reminders LMP",
          "bool_expr": "doc.fields.last_menstrual_period && /^[0-9]+$/.test(doc.fields.last_menstrual_period)"
        },
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "ANC Reminders",
          "bool_expr": "!doc.fields.last_menstrual_period || !(/^[0-9]+$/.test(doc.fields.last_menstrual_period))"
        },
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "Delivery Reminders",
          "bool_expr": "!doc.fields.last_menstrual_period || !(/^[0-9]+$/.test(doc.fields.last_menstrual_period))"
        },
        {
          "name": "on_create",
          "trigger": "clear_schedule",
          "params": "ANC Reminders LMP from App, ANC Reminders LMP, ANC Reminders, Delivery Reminders LMP from App, Delivery Reminders LMP, Delivery Reminders, Postnatal Care, Postnatal Care for Facility Birth, Postnatal Care from App, Registration Followup ANC, Registration Followup ANC PNC",
          "bool_expr": ""
        }
      ],
      "validations": {
        "join_responses": true,
        "list": [
          {
            "property": "patient_id",
            "rule": "regex('^[0-9]{5,13}$')",
            "translation_key": "messages.generic.validation.patient_id"
          },
          {
            "property": "last_menstrual_period",
            "rule": "lenMin(1) ? (integer && between(2,42)) : optional",
            "translation_key": "messages.p.validation.last_menstrual_period"
          }
        ]
      },
      "messages": [
        {
          "translation_key": "messages.generic.registration_not_found",
          "event_type": "registration_not_found",
          "recipient": "reporting_unit"
        },
        {
          "translation_key": "messages.p.report_accepted",
          "event_type": "report_accepted",
          "recipient": "reporting_unit"
        }
      ]
    },
    {
      "form": "D",
      "events": [
        {
          "name": "on_create",
          "trigger": "add_birth_date",
          "params": "days_since_birth",
          "bool_expr": "doc.fields.days_since_birth || doc.fields.days_since_birth === 0"
        },
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "Postnatal Care",
          "bool_expr": "var isCoveredByUseCase=function(e,s){return!e||(e&&'string'==typeof e.use_cases?-1!==e.use_cases.split(' ').indexOf(s):isCoveredByUseCase(e.parent,s))}; isCoveredByUseCase(doc.contact, 'pnc') && doc.fields.days_since_birth && /^[0-9]+$/.test(doc.fields.days_since_birth) && !(doc.fields.delivery_code === 'f' || doc.fields.delivery_code === 'F')"
        },
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "Postnatal Care for Facility Birth",
          "bool_expr": "var isCoveredByUseCase=function(e,s){return!e||(e&&'string'==typeof e.use_cases?-1!==e.use_cases.split(' ').indexOf(s):isCoveredByUseCase(e.parent,s))}; isCoveredByUseCase(doc.contact, 'pnc') && doc.fields.days_since_birth && /^[0-9]+$/.test(doc.fields.days_since_birth) && (doc.fields.delivery_code === 'f' || doc.fields.delivery_code === 'F')"
        },
        {
          "name": "on_create",
          "trigger": "clear_schedule",
          "params": "ANC Reminders LMP from App, ANC Reminders LMP, ANC Reminders, Delivery Reminders LMP from App, Delivery Reminders LMP, Delivery Reminders, Postnatal Care, Postnatal Care for Facility Birth, Postnatal Care from App, Registration Followup ANC, Registration Followup ANC PNC",
          "bool_expr": ""
        }
      ],
      "validations": {
        "join_responses": true,
        "list": [
          {
            "property": "patient_id",
            "rule": "regex('^[0-9]{5,13}$')",
            "translation_key": "messages.generic.validation.patient_id"
          },
          {
            "property": "delivery_code",
            "rule": "regex('^(F|f|S|s|Ns|NS|ns|nS)$')",
            "translation_key": "messages.d.validation.delivery_code"
          },
          {
            "property": "days_since_birth",
            "rule": "lenMin(1) ? (integer && regex('^[0-9]{1,3}$') && between(0,365)) : optional",
            "translation_key": "messages.d.validation.days_since_birth"
          }
        ]
      },
      "messages": [
        {
          "translation_key": "messages.d.report_accepted",
          "event_type": "report_accepted",
          "recipient": "reporting_unit"
        },
        {
          "translation_key": "messages.generic.registration_not_found",
          "event_type": "registration_not_found",
          "recipient": "reporting_unit"
        }
      ]
    },
    {
      "form": "delivery",
      "events": [
        {
          "name": "on_create",
          "trigger": "assign_schedule",
          "params": "Postnatal Care from App",
          "bool_expr": "var isCoveredByUseCase=function(e,s){return!e||(e&&'string'==typeof e.use_cases?-1!==e.use_cases.split(' ').indexOf(s):isCoveredByUseCase(e.parent,s))}; isCoveredByUseCase(doc.contact, 'pnc')"
        },
        {
          "name": "on_create",
          "trigger": "clear_schedule",
          "params": "ANC Reminders LMP from App, ANC Reminders LMP, ANC Reminders, Delivery Reminders LMP from App, Delivery Reminders LMP, Delivery Reminders, Postnatal Care, Postnatal Care for Facility Birth, Postnatal Care from App, Registration Followup ANC, Registration Followup ANC PNC",
          "bool_expr": ""
        }
      ],
      "validations": {},
