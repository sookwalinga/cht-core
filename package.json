{
  "name": "capacity-building-config",
  "version": "0.1.0",
  "description": "",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "eslint": "npx eslint *.json *.js 'test/**/*.js'",
    "test": "npm run compile-forms && npm run compile-app-settings && npm run test-unit",
    "compile-app-settings": "node ./node_modules/medic-conf/src/bin/medic-conf.js --no-check compile-app-settings",
    "compile-forms": "node ./node_modules/medic-conf/src/bin/medic-conf.js --no-check convert-app-forms convert-contact-forms",
    "test-unit": "mocha test/**/*.spec.js --timeout 45000 --slow 500",
    "dev-form": "ls -R1a forms/app/*.xlsx | entr ./node_modules/medic-conf/src/bin/medic-conf.js convert-app-forms -- ",
    "sqlfluff": "sqlfluff lint --ignore .sqlfluffignore --config .sqlfluff -n postgres/"
  },
  "devDependencies": {
    "@medic/eslint-config": "^1.1.0",
    "@medic/contact-summary-testing": "^1.1.3",
    "chai": "^4.2.0",
    "chai-exclude": "^1.0.8",
    "eslint": "^6.8.0",
    "eslint-plugin-json": "^2.0.1",
    "medic-conf": "^3.2.0",
    "medic-nootils": "^4.0.1",
    "mocha": "^5.1.1"
  },
  "dependencies": {
    "chai-date-string": "^0.1.0",
    "chai-datetime": "^1.5.0",
    "medic-conf-test-harness": "^0.1.20"
  }
}
