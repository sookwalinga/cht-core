<?xml version="1.0"?>
<h:html xmlns="http://www.w3.org/2002/xforms" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:h="http://www.w3.org/1999/xhtml" xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <h:head>
    <h:title>Rekebisha taarifa za kaya</h:title>
    <model>
      <itext>
        <translation lang="en">
          <text id="/data/clinic/name:label">
            <value>Please enter the household name:</value>
          </text>
          <text id="/data/inputs/user/contact_id:label">
            <value>Contact ID of the logged in user</value>
          </text>
          <text id="/data/inputs/user/facility_id:label">
            <value>Place ID of the logged in user</value>
          </text>
          <text id="/data/inputs/user/name:label">
            <value>Name of the logged in user</value>
          </text>
        </translation>
        <translation lang="sw">
          <text id="/data/clinic/name:label">
            <value>Ingiza jina la nyumba:</value>
          </text>
          <text id="/data/clinic:label">
            <value>-</value>
          </text>
          <text id="/data/inputs/user/contact_id:label">
            <value>Mawasiliano ya mtumizi</value>
          </text>
          <text id="/data/inputs/user/facility_id:label">
            <value>Mahali ya kitambulisho ya Mtumizi</value>
          </text>
          <text id="/data/inputs/user/name:label">
            <value>Jina la mtumizi</value>
          </text>
        </translation>
      </itext>
      <instance>
        <data delimiter="#" id="contact:clinic:edit" prefix="J1!contact:clinic:edit!" version="2019-06-28_13-04">
          <inputs>
            <meta>
              <location>
                <lat/>
                <long/>
                <error/>
                <message/>
              </location>
            </meta>
            <user>
              <name/>
              <contact_id/>
              <facility_id/>
            </user>
          </inputs>
          <clinic>
            <name/>
            <edited_date/>
            <meta tag="hidden">
              <created_by/>
              <created_by_person_uuid/>
              <created_by_place_uuid/>
              <last_edited_by/>
              <last_edited_by_person_uuid/>
              <last_edited_by_place_uuid/>
            </meta>
          </clinic>
          <meta tag="hidden">
            <instanceID/>
          </meta>
        </data>
      </instance>
      <bind nodeset="/data/inputs" relevant="false()"/>
      <bind nodeset="/data/inputs/user/name" type="string"/>
      <bind nodeset="/data/inputs/user/contact_id" type="string"/>
      <bind nodeset="/data/inputs/user/facility_id" type="string"/>
      <bind nodeset="/data/clinic/name" required="true()" type="string"/>
      <bind calculate="int(decimal-date-time(now())* 24 *60*60*1000)" nodeset="/data/clinic/edited_date" type="string"/>
      <bind nodeset="/data/clinic/meta/created_by" readonly="true()" type="string"/>
      <bind nodeset="/data/clinic/meta/created_by_person_uuid" readonly="true()" type="string"/>
      <bind nodeset="/data/clinic/meta/created_by_place_uuid" readonly="true()" type="string"/>
      <bind calculate="../../../inputs/user/name" nodeset="/data/clinic/meta/last_edited_by" type="string"/>
      <bind calculate="../../../inputs/user/contact_id" nodeset="/data/clinic/meta/last_edited_by_person_uuid" type="string"/>
      <bind calculate="../../../inputs/user/facility_id" nodeset="/data/clinic/meta/last_edited_by_place_uuid" type="string"/>
      <bind calculate="concat('uuid:', uuid())" nodeset="/data/meta/instanceID" readonly="true()" type="string"/>
    </model>
  </h:head>
  <h:body class="pages">
    <group ref="/data/inputs">
      <group ref="/data/inputs/user">
        <input ref="/data/inputs/user/name">
          <label ref="jr:itext('/data/inputs/user/name:label')"/>
        </input>
        <input ref="/data/inputs/user/contact_id">
          <label ref="jr:itext('/data/inputs/user/contact_id:label')"/>
        </input>
        <input ref="/data/inputs/user/facility_id">
          <label ref="jr:itext('/data/inputs/user/facility_id:label')"/>
        </input>
      </group>
    </group>
    <group ref="/data/clinic">
      <input ref="/data/clinic/name">
        <label ref="jr:itext('/data/clinic/name:label')"/>
      </input>
      <group appearance="hidden" ref="/data/clinic/meta"/>
    </group>
  </h:body>
</h:html>
