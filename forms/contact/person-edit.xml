      <bind nodeset="/data/person/kym_id" readonly="true()" type="string" calculate=" /data/person/barcode/android-app-outputs/SCAN_RESULT "/>
      <bind nodeset="/data/person/kym_message" relevant=" /data/project_c =&quot;kadiyamatibabu&quot; and  /data/person/kym_id ='' and  /data/person/kadi_ya_matibabu_id =''"/>
      <bind nodeset="/data/person/kym_message/kym_message_title" readonly="true()" type="string"/>
      <bind nodeset="/data/person/kym_message/kym_message_note" readonly="true()" type="string"/>
      <bind nodeset="/data/person/display_health_card_id" type="string" calculate="if( /data/person/kym_id !='', /data/person/kym_id ,  /data/person/kadi_ya_matibabu_id )"/>
      <bind nodeset="/data/person/has_health_card_id" type="select1" relevant=" /data/project_c =&quot;kadiyamatibabu&quot;"/>
      <bind nodeset="/data/person/scan_kym_id_note" readonly="true()" type="string" relevant=" /data/project_c =&quot;kadiyamatibabu&quot; and selected( /data/person/has_health_card_id ,&quot;yes&quot;)"/>
      <bind nodeset="/data/person/is_client_in_kym_app" type="select1" required="true()" relevant=" /data/project_c =&quot;kadiyamatibabu&quot; and selected( /data/person/has_health_card_id ,&quot;no&quot;)"/>
      <bind nodeset="/data/person/barcode" relevant=" /data/project_c =&quot;kadiyamatibabu&quot; and
(selected( /data/person/has_health_card_id ,&quot;yes&quot;) or 
(selected( /data/person/has_health_card_id ,&quot;no&quot;) and selected( /data/person/is_client_in_kym_app ,&quot;no&quot;)))"/>
      <bind nodeset="/data/person/barcode/action" type="string"/>
      <bind nodeset="/data/person/barcode/android-app-outputs/SCAN_RESULT" type="string"/>
      <bind nodeset="/data/person/register_client_note_read_only" readonly="true()" type="string" relevant=" /data/project_c =&quot;kadiyamatibabu&quot; and selected( /data/person/has_health_card_id ,&quot;no&quot;) and selected( /data/person/is_client_in_kym_app ,&quot;no&quot;)"/>
      <bind nodeset="/data/person/kadi_ya_matibabu_id_read_only" readonly="true()" type="string" jr:constraintMsg="jr:itext('/data/person/kadi_ya_matibabu_id_read_only:jr:constraintMsg')" relevant=" /data/project_c =&quot;kadiyamatibabu&quot; and 
 (selected( /data/person/has_health_card_id ,&quot;yes&quot;) or (selected( /data/person/has_health_card_id ,&quot;no&quot;) and selected( /data/person/is_client_in_kym_app ,&quot;no&quot;)))" calculate=" /data/person/barcode/android-app-outputs/SCAN_RESULT " constraint="regex(., '^\d{12}$')"/>
      <bind nodeset="/data/person/resigter_client_note_manually" readonly="true()" type="string" relevant=" /data/project_c =&quot;kadiyamatibabu&quot; and 
selected( /data/person/has_health_card_id ,&quot;no&quot;) and selected( /data/person/is_client_in_kym_app ,&quot;yes&quot;)"/>
      <bind nodeset="/data/person/kadi_ya_matibabu_id_text_field" readonly="false()" type="string" jr:constraintMsg="jr:itext('/data/person/kadi_ya_matibabu_id_text_field:jr:constraintMsg')" relevant=" /data/project_c =&quot;kadiyamatibabu&quot; and 
selected( /data/person/has_health_card_id ,&quot;no&quot;) and selected( /data/person/is_client_in_kym_app ,&quot;yes&quot;)" constraint="regex(., '^\d{12}$')"/>
      <bind nodeset="/data/person/kadi_ya_matibabu_id" type="string" calculate="if( /data/person/kadi_ya_matibabu_id_text_field !='', /data/person/kadi_ya_matibabu_id_text_field , /data/person/kadi_ya_matibabu_id )"/>
      <bind nodeset="/data/person/first_name" type="string" required="true()"/>
      <bind nodeset="/data/person/middle_name" type="string" required="true()"/>
      <bind nodeset="/data/person/last_name" type="string" required="true()"/>
      <bind nodeset="/data/person/is_head_of_household" type="string"/>
      <bind nodeset="/data/person/date_of_birth" type="date" required="true()" constraint=". &lt;= today()" jr:constraintMsg="jr:itext('/data/person/date_of_birth:jr:constraintMsg')"/>
      <bind nodeset="/data/person/phone" type="string" required="true()" jr:constraintMsg="jr:itext('/data/person/phone:jr:constraintMsg')" relevant=" /data/person/is_head_of_household =&quot;yes&quot;" constraint="regex(.,'^0[0-9]{9}$')"/>
      <bind nodeset="/data/person/phone_alternate" type="string" jr:constraintMsg="jr:itext('/data/person/phone_alternate:jr:constraintMsg')" relevant=" /data/person/is_head_of_household =&quot;yes&quot;" constraint="regex(.,'^0[0-9]{9}$')"/>
      <bind nodeset="/data/person/sex" type="select1" required="true()"/>
      <bind nodeset="/data/person/first_name_c" type="string" calculate="../first_name"/>
      <bind nodeset="/data/person/middle_name_c" type="string" calculate="../middle_name"/>
      <bind nodeset="/data/person/last_name_c" type="string" calculate="../last_name"/>
      <bind nodeset="/data/person/name" type="string" calculate="concat( /data/person/first_name_c ,&quot; &quot;,  /data/person/middle_name_c ,&quot; &quot;,  /data/person/last_name_c )"/>
      <bind nodeset="/data/person/edited_date" type="string" calculate="int(decimal-date-time(now())* 24 *60*60*1000)"/>
      <bind nodeset="/data/person/meta/created_by" type="string" readonly="true()"/>
      <bind nodeset="/data/person/meta/created_by_person_uuid" type="string" readonly="true()"/>
      <bind nodeset="/data/person/meta/created_by_place_uuid" type="string" readonly="true()"/>
      <bind nodeset="/data/person/meta/last_edited_by" type="string" calculate="../../../inputs/user/name"/>
      <bind nodeset="/data/person/meta/last_edited_by_person_uuid" type="string" calculate="../../../inputs/user/contact_id"/>
      <bind nodeset="/data/person/meta/last_edited_by_place_uuid" type="string" calculate="../../../inputs/user/facility_id"/>
      <bind nodeset="/data/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
