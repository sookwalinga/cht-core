          <text id="/data/person/first_name:jr:constraintMsg">
            <value>Jaza jina la kwanza</value>
          </text>
          <text id="/data/person/first_name:label">
            <value>Ni lipi jina lake la kwanza?</value>
          </text>
          <text id="/data/person/hh_member_note:label">
            <value>_Fomu hii ni kwa ajili ya kuongeza mwanafamilia mpya wa nyumba hii. Tafadhali ingiza taarifa za mwanafamilia huyo hapa._</value>
          </text>
          <text id="/data/person/last_name:jr:constraintMsg">
            <value>Jaza jina la babu</value>
          </text>
          <text id="/data/person/last_name:label">
            <value>Ni lipi jina la babu yake?</value>
          </text>
