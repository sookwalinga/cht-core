          </text>
          <text id="/data/person/exact_dob_known/yes:label">
            <value>Yes</value>
          </text>
          <text id="/data/person/exact_dob_known:hint">
            <value>Note that for children under age 5, you will have to enter an exact date of birth.</value>
          </text>
          <text id="/data/person/exact_dob_known:label">
            <value>Do you know <output value=" /data/person/first_name_c "/>'s exact date of birth?</value>
          </text>
          <text id="/data/person/first_name:jr:constraintMsg">
            <value>Enter a first name</value>
          </text>
          <text id="/data/person/first_name:label">
            <value>What is their first name?</value>
          </text>
          <text id="/data/person/hh_member_note:label">
            <value>_This form will add a new member to an existing household. Please enter information for the member of the that you would like to add._</value>
          </text>
          <text id="/data/person/last_name:jr:constraintMsg">
            <value>Enter a family name</value>
