          </person>
          <contact_id/>
          <facility_id/>
          <name/>
          <project_c/>
          <covid19_intro>
            <covid19_intro_note/>
          </covid19_intro>
          <not_in_household_note/>
          <not_in_household_flag/>
          <kym_message>
            <kym_message_note/>
          </kym_message>
          <meta tag="hidden">
            <instanceID/>
          </meta>
        </data>
      </instance>
      <bind nodeset="/data/inputs" relevant="false()"/>
      <bind nodeset="/data/inputs/user/contact_id" type="string"/>
      <bind nodeset="/data/inputs/user/facility_id" type="string"/>
      <bind nodeset="/data/inputs/user/name" type="string"/>
      <bind nodeset="/data/inputs/user/project" type="string"/>
      <bind nodeset="/data/inputs/contact/_id" type="db:person"/>
      <bind nodeset="/data/contact_id" type="string" calculate="../inputs/user/contact_id"/>
      <bind nodeset="/data/facility_id" type="string" calculate="../inputs/user/facility_id"/>
      <bind nodeset="/data/name" type="string" calculate="../inputs/user/name"/>
      <bind nodeset="/data/project_c" type="string" calculate="../inputs/user/project"/>
      <bind nodeset="/data/covid19_intro/covid19_intro_note" readonly="true()" type="string"/>
      <bind nodeset="/data/not_in_household_note" readonly="true()" type="string" relevant="starts-with( /data/person/parent , ../facility_id)"/>
      <bind nodeset="/data/not_in_household_flag" type="string" calculate="if(starts-with( /data/person/parent , ../facility_id),1,0)"/>
      <bind nodeset="/data/kym_message" relevant=" /data/not_in_household_flag  = 0 and  /data/project_c =&quot;kadiyamatibabu&quot;"/>
      <bind nodeset="/data/kym_message/kym_message_note" readonly="true()" type="string"/>
      <bind nodeset="/data/person/hh_member_note" readonly="true()" type="string" relevant=" /data/not_in_household_flag  = 0"/>
      <bind nodeset="/data/person/type" type="string"/>
      <bind nodeset="/data/person/parent" type="string" calculate="."/>
      <bind nodeset="/data/person/first_name" type="string" relevant=" /data/not_in_household_flag  = 0" jr:constraintMsg="jr:itext('/data/person/first_name:jr:constraintMsg')" constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2" required="true()"/>
      <bind nodeset="/data/person/middle_name" type="string" relevant=" /data/not_in_household_flag  = 0" jr:constraintMsg="jr:itext('/data/person/middle_name:jr:constraintMsg')" constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2" required="true()"/>
      <bind nodeset="/data/person/last_name" type="string" relevant=" /data/not_in_household_flag  = 0" jr:constraintMsg="jr:itext('/data/person/last_name:jr:constraintMsg')" constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2" required="true()"/>
      <bind nodeset="/data/person/first_name_c" type="string" calculate="../first_name"/>
      <bind nodeset="/data/person/middle_name_c" type="string" calculate="../middle_name"/>
      <bind nodeset="/data/person/last_name_c" type="string" calculate="../last_name"/>
      <bind nodeset="/data/person/name" type="string" calculate="concat( /data/person/first_name_c ,&quot; &quot;,  /data/person/middle_name_c ,&quot; &quot;,  /data/person/last_name_c )"/>
      <bind nodeset="/data/person/sex_note" readonly="true()" type="string" relevant=" /data/not_in_household_flag  = 0"/>
      <bind nodeset="/data/person/sex" type="select1" relevant=" /data/not_in_household_flag  = 0" required="true()"/>
      <bind nodeset="/data/person/sex_c" type="string" calculate="../sex"/>
      <bind nodeset="/data/person/exact_dob_known" type="select1" relevant=" /data/not_in_household_flag  = 0" required="true()"/>
      <bind nodeset="/data/person/exact_dob_known_c" type="string" calculate="../exact_dob_known"/>
      <bind nodeset="/data/person/age_estimate_contact" type="int" relevant=" /data/person/exact_dob_known_c  = &quot;no&quot;" jr:constraintMsg="jr:itext('/data/person/age_estimate_contact:jr:constraintMsg')" constraint=". &gt;= 5 and . &lt;= 100" required="true()"/>
      <bind nodeset="/data/person/yob" type="string" calculate="if(../age_estimate_contact != '', format-date-time(today(),&quot;%Y&quot;) - ../age_estimate_contact, 1900)"/>
      <bind nodeset="/data/person/dob" type="date" relevant=" /data/person/exact_dob_known_c =&quot;yes&quot;" jr:constraintMsg="jr:itext('/data/person/dob:jr:constraintMsg')" constraint=". &lt;= date-time(decimal-date-time(today())) and . &gt;= date-time(decimal-date-time(today() - (100 * 365.25)))" required="true()"/>
      <bind nodeset="/data/person/temp_hh_member" type="select1" relevant=" /data/not_in_household_flag  = 0" required="true()"/>
      <bind nodeset="/data/person/date_of_birth" type="string" calculate="format-date(if(../dob != '', ../dob,concat(../yob, '-01-01')), '%Y-%m-%d')"/>
      <bind nodeset="/data/person/date_of_birth_c" type="string" calculate="../date_of_birth"/>
      <bind nodeset="/data/person/is_exact_dob_in_range" type="string" calculate="if((../date_of_birth_c &lt;= date-time(decimal-date-time(today())) and ../date_of_birth_c &gt;= date-time(decimal-date-time(today() - (100 * 365.25)))),1,0)"/>
      <bind nodeset="/data/person/reproductive_age" type="string" calculate="if( /data/person/sex_c =&quot;female&quot; and ((((decimal-date-time(today()) - decimal-date-time( /data/person/date_of_birth_c )) div 365) &gt;= 15 and ((decimal-date-time(today()) - decimal-date-time( /data/person/date_of_birth_c )) div 365) &lt;= 49)),int(1),int(0))"/>
      <bind nodeset="/data/person/is_under_5_binary" type="string" calculate="if(((decimal-date-time(today()) - decimal-date-time( /data/person/date_of_birth_c )) div 30) &lt; 60,1,0)"/>
      <bind nodeset="/data/person/age_days" type="string" calculate="int(decimal-date-time(now())-decimal-date-time( /data/person/date_of_birth_c ))"/>
      <bind nodeset="/data/person/return_child_note_20_or_above_days" readonly="true()" type="string" relevant=" /data/person/exact_dob_known_c =&quot;yes&quot; and  /data/person/is_under_5_binary =1 and  /data/person/is_exact_dob_in_range  = 1 and  /data/person/age_days  &gt;= 20"/>
      <bind nodeset="/data/person/return_infant_note_under_20_days" readonly="true()" type="string" relevant=" /data/person/age_days  &lt; 20"/>
      <bind nodeset="/data/person/return_women_note" readonly="true()" type="string" relevant=" /data/person/reproductive_age  = 1"/>
      <bind nodeset="/data/person/debug_note" readonly="true()" type="string"/>
      <bind nodeset="/data/person/has_health_card_id" type="select1" relevant=" /data/project_c =&quot;kadiyamatibabu&quot;" required="true()"/>
      <bind nodeset="/data/person/scan_kym_id_note" readonly="true()" type="string" relevant="selected( /data/person/has_health_card_id ,&quot;yes&quot;)"/>
      <bind nodeset="/data/person/is_client_in_kym_app" type="select1" relevant="selected( /data/person/has_health_card_id ,&quot;no&quot;)" required="true()"/>
      <bind nodeset="/data/person/register_client_note_read_only" readonly="true()" type="string" relevant="(selected( /data/person/has_health_card_id ,&quot;no&quot;) and selected( /data/person/is_client_in_kym_app ,&quot;no&quot;))"/>
      <bind nodeset="/data/person/barcode" relevant="selected( /data/person/has_health_card_id ,&quot;yes&quot;) or (selected( /data/person/has_health_card_id ,&quot;no&quot;) and selected( /data/person/is_client_in_kym_app ,&quot;no&quot;))"/>
      <bind nodeset="/data/person/barcode/action" type="string"/>
      <bind nodeset="/data/person/barcode/android-app-outputs/SCAN_RESULT" type="string"/>
      <bind nodeset="/data/person/kadi_ya_matibabu_id_read_only" readonly="true()" type="string" relevant="selected( /data/person/has_health_card_id ,&quot;yes&quot;) or
(selected( /data/person/has_health_card_id ,&quot;no&quot;) and selected( /data/person/is_client_in_kym_app ,&quot;no&quot;))" calculate=" /data/person/barcode/android-app-outputs/SCAN_RESULT " jr:constraintMsg="jr:itext('/data/person/kadi_ya_matibabu_id_read_only:jr:constraintMsg')" constraint="regex(., '^\d{12}$')"/>
      <bind nodeset="/data/person/resigter_client_note_manually" readonly="true()" type="string" relevant="selected( /data/person/has_health_card_id ,&quot;no&quot;) and selected( /data/person/is_client_in_kym_app ,&quot;yes&quot;)"/>
      <bind nodeset="/data/person/kadi_ya_matibabu_id" readonly="false()" type="string" relevant="selected( /data/person/has_health_card_id ,&quot;no&quot;) and selected( /data/person/is_client_in_kym_app ,&quot;yes&quot;)" jr:constraintMsg="jr:itext('/data/person/kadi_ya_matibabu_id:jr:constraintMsg')" constraint="regex(., '^\d{12}$')"/>
      <bind nodeset="/data/person/meta/created_by" type="string" calculate="../../../name"/>
      <bind nodeset="/data/person/meta/created_by_person_uuid" type="string" calculate="../../../contact_id"/>
      <bind nodeset="/data/person/meta/created_by_place_uuid" type="string" calculate="../../../facility_id"/>
      <bind nodeset="/data/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
    </model>
  </h:head>
  <h:body class="pages">
    <group ref="/data/inputs">
