          <text id="/data/person/dob:jr:constraintMsg">
            <value>You've entered a birthdate either in the future or very long ago - confirm that you've entered it properly.</value>
          </text>
          <text id="/data/person/dob:label">
            <value>What is <output value=" /data/person/first_name_c "/>'s date of birth?</value>
