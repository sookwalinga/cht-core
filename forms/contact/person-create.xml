            <value>-</value>
          </text>
          <text id="/data/inputs/user/facility_id:label">
            <value>-</value>
          </text>
          <text id="/data/inputs/user/name:label">
            <value>-</value>
          </text>
          <text id="/data/inputs/user:label">
