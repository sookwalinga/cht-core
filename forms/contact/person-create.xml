          </text>
          <text id="/data/person/return_women_note:label">
            <value>Umri wa <output value=" /data/person/first_name_c "/> unaonesha kwamba anaweza kupata ujauzito. Ningeomba ridhaa yako kurudia ili kuja kuzungumza naye mambo muhimu ya afya kipindi cha ujauzito na baada ya kujifungua.</value>
          </text>
          <text id="/data/person/sex/female:label">
            <value>Mwanamke</value>
          </text>
          <text id="/data/person/sex/male:label">
            <value>Mwanamme</value>
          </text>
          <text id="/data/person/sex:label">
            <value>Ingiza jinsia yake</value>
          </text>
          <text id="/data/person/sex_note:label">
            <value>&lt;span style="color:red;font-style: italic"&gt;Usimsomee, jaza wewe (CHV). &lt;/span&gt;</value>
          </text>
          <text id="/data/person/temp_hh_member/permanent:label">
            <value>Mkaazi wa kudumu - Hatohamia sehemu nyengine</value>
          </text>
          <text id="/data/person/temp_hh_member/temporary:label">
            <value>Mkaazi wa muda - Atahamia sehemu nyengine</value>
          </text>
          <text id="/data/person/temp_hh_member:label">
            <value>Je <output value=" /data/person/first_name_c "/> ni mkazi wa kudumu katika nyumba hii au ni mkazi wa muda tu?</value>
          </text>
          <text id="/data/person/type:label">
            <value>-</value>
          </text>
          <text id="/data/person:label">
            <value>Taarifa za wanakaya</value>
          </text>
        </translation>
      </itext>
      <instance>
        <data id="contact:person:create" prefix="J1!contact:person:create!" delimiter="#" version="2020-04-15_02-49">
          <inputs>
            <meta>
              <location>
                <lat/>
                <long/>
                <error/>
                <message/>
              </location>
            </meta>
            <user>
              <contact_id/>
              <facility_id/>
              <name/>
            </user>
          </inputs>
          <person>
            <hh_member_note/>
            <type>person</type>
            <parent>PARENT</parent>
            <first_name/>
            <middle_name/>
            <last_name/>
            <first_name_c/>
            <middle_name_c/>
            <last_name_c/>
            <name/>
            <sex_note/>
            <sex/>
            <sex_c/>
            <exact_dob_known/>
            <exact_dob_known_c/>
            <age_estimate_contact/>
            <yob/>
            <dob/>
            <temp_hh_member/>
            <date_of_birth/>
            <date_of_birth_c/>
            <is_exact_dob_in_range/>
            <reproductive_age/>
            <is_under_5_binary/>
            <age_days/>
            <return_child_note_20_or_above_days/>
            <return_infant_note_under_20_days/>
            <return_women_note/>
            <debug_note/>
            <meta tag="hidden">
              <created_by/>
              <created_by_person_uuid/>
              <created_by_place_uuid/>
            </meta>
          </person>
          <contact_id/>
          <facility_id/>
          <name/>
          <covid19_intro>
            <covid19_intro_note/>
          </covid19_intro>
          <not_in_household_note/>
          <not_in_household_flag/>
          <meta tag="hidden">
            <instanceID/>
          </meta>
        </data>
      </instance>
      <bind nodeset="/data/inputs" relevant="false()"/>
      <bind nodeset="/data/inputs/user/contact_id" type="string"/>
      <bind nodeset="/data/inputs/user/facility_id" type="string"/>
      <bind nodeset="/data/inputs/user/name" type="string"/>
      <bind nodeset="/data/contact_id" type="string" calculate="../inputs/user/contact_id"/>
      <bind nodeset="/data/facility_id" type="string" calculate="../inputs/user/facility_id"/>
      <bind nodeset="/data/name" type="string" calculate="../inputs/user/name"/>
      <bind nodeset="/data/covid19_intro/covid19_intro_note" readonly="true()" type="string"/>
      <bind nodeset="/data/not_in_household_note" readonly="true()" type="string" relevant="starts-with( /data/person/parent , ../facility_id)"/>
      <bind nodeset="/data/not_in_household_flag" type="string" calculate="if(starts-with( /data/person/parent , ../facility_id),1,0)"/>
      <bind nodeset="/data/person/hh_member_note" readonly="true()" type="string" relevant=" /data/not_in_household_flag  = 0"/>
      <bind nodeset="/data/person/type" type="string"/>
      <bind nodeset="/data/person/parent" type="string" calculate="."/>
      <bind nodeset="/data/person/first_name" type="string" required="true()" relevant=" /data/not_in_household_flag  = 0" jr:constraintMsg="jr:itext('/data/person/first_name:jr:constraintMsg')" constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2"/>
      <bind nodeset="/data/person/middle_name" type="string" required="true()" relevant=" /data/not_in_household_flag  = 0" jr:constraintMsg="jr:itext('/data/person/middle_name:jr:constraintMsg')" constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2"/>
      <bind nodeset="/data/person/last_name" type="string" required="true()" relevant=" /data/not_in_household_flag  = 0" jr:constraintMsg="jr:itext('/data/person/last_name:jr:constraintMsg')" constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2"/>
      <bind nodeset="/data/person/first_name_c" type="string" calculate="../first_name"/>
      <bind nodeset="/data/person/middle_name_c" type="string" calculate="../middle_name"/>
      <bind nodeset="/data/person/last_name_c" type="string" calculate="../last_name"/>
      <bind nodeset="/data/person/name" type="string" calculate="concat( /data/person/first_name_c ,&quot; &quot;,  /data/person/middle_name_c ,&quot; &quot;,  /data/person/last_name_c )"/>
      <bind nodeset="/data/person/sex_note" readonly="true()" type="string" relevant=" /data/not_in_household_flag  = 0"/>
      <bind nodeset="/data/person/sex" type="select1" relevant=" /data/not_in_household_flag  = 0" required="true()"/>
      <bind nodeset="/data/person/sex_c" type="string" calculate="../sex"/>
      <bind nodeset="/data/person/exact_dob_known" type="select1" relevant=" /data/not_in_household_flag  = 0" required="true()"/>
      <bind nodeset="/data/person/exact_dob_known_c" type="string" calculate="../exact_dob_known"/>
      <bind nodeset="/data/person/age_estimate_contact" type="int" required="true()" relevant=" /data/person/exact_dob_known_c  = &quot;no&quot;" jr:constraintMsg="jr:itext('/data/person/age_estimate_contact:jr:constraintMsg')" constraint=". &gt;= 5 and . &lt;= 100"/>
      <bind nodeset="/data/person/yob" type="string" calculate="if(../age_estimate_contact != '', format-date-time(today(),&quot;%Y&quot;) - ../age_estimate_contact, 1900)"/>
      <bind nodeset="/data/person/dob" type="date" required="true()" relevant=" /data/person/exact_dob_known_c =&quot;yes&quot;" jr:constraintMsg="jr:itext('/data/person/dob:jr:constraintMsg')" constraint=". &lt;= date-time(decimal-date-time(today())) and . &gt;= date-time(decimal-date-time(today() - (100 * 365.25)))"/>
      <bind nodeset="/data/person/temp_hh_member" type="select1" required="true()" relevant=" /data/not_in_household_flag  = 0"/>
      <bind nodeset="/data/person/date_of_birth" type="string" calculate="format-date(if(../dob != '', ../dob,concat(../yob, '-01-01')), '%Y-%m-%d')"/>
      <bind nodeset="/data/person/date_of_birth_c" type="string" calculate="../date_of_birth"/>
      <bind nodeset="/data/person/is_exact_dob_in_range" type="string" calculate="if((../date_of_birth_c &lt;= date-time(decimal-date-time(today())) and ../date_of_birth_c &gt;= date-time(decimal-date-time(today() - (100 * 365.25)))),1,0)"/>
      <bind nodeset="/data/person/reproductive_age" type="string" calculate="if( /data/person/sex_c =&quot;female&quot; and ((((decimal-date-time(today()) - decimal-date-time( /data/person/date_of_birth_c )) div 365) &gt;= 15 and ((decimal-date-time(today()) - decimal-date-time( /data/person/date_of_birth_c )) div 365) &lt;= 49)),int(1),int(0))"/>
      <bind nodeset="/data/person/is_under_5_binary" type="string" calculate="if(((decimal-date-time(today()) - decimal-date-time( /data/person/date_of_birth_c )) div 30) &lt; 60,1,0)"/>
      <bind nodeset="/data/person/age_days" type="string" calculate="int(decimal-date-time(now())-decimal-date-time( /data/person/date_of_birth_c ))"/>
      <bind nodeset="/data/person/return_child_note_20_or_above_days" readonly="true()" type="string" relevant=" /data/person/exact_dob_known_c =&quot;yes&quot; and  /data/person/is_under_5_binary =1 and  /data/person/is_exact_dob_in_range  = 1 and  /data/person/age_days  &gt;= 20"/>
      <bind nodeset="/data/person/return_infant_note_under_20_days" readonly="true()" type="string" relevant=" /data/person/age_days  &lt; 20"/>
      <bind nodeset="/data/person/return_women_note" readonly="true()" type="string" relevant=" /data/person/reproductive_age  = 1"/>
      <bind nodeset="/data/person/debug_note" readonly="true()" type="string"/>
      <bind nodeset="/data/person/meta/created_by" type="string" calculate="../../../name"/>
      <bind nodeset="/data/person/meta/created_by_person_uuid" type="string" calculate="../../../contact_id"/>
      <bind nodeset="/data/person/meta/created_by_place_uuid" type="string" calculate="../../../facility_id"/>
      <bind nodeset="/data/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
    </model>
  </h:head>
  <h:body class="pages">
    <group ref="/data/inputs">
      <group ref="/data/inputs/user">
        <input ref="/data/inputs/user/contact_id">
          <label ref="jr:itext('/data/inputs/user/contact_id:label')"/>
        </input>
        <input ref="/data/inputs/user/facility_id">
          <label ref="jr:itext('/data/inputs/user/facility_id:label')"/>
        </input>
        <input ref="/data/inputs/user/name">
          <label ref="jr:itext('/data/inputs/user/name:label')"/>
        </input>
      </group>
    </group>
    <group ref="/data/covid19_intro">
      <label ref="jr:itext('/data/covid19_intro:label')"/>
      <input ref="/data/covid19_intro/covid19_intro_note">
        <label ref="jr:itext('/data/covid19_intro/covid19_intro_note:label')"/>
      </input>
    </group>
    <input ref="/data/not_in_household_note">
      <label ref="jr:itext('/data/not_in_household_note:label')"/>
    </input>
    <group appearance="field-list" ref="/data/person">
      <label ref="jr:itext('/data/person:label')"/>
      <input ref="/data/person/hh_member_note">
        <label ref="jr:itext('/data/person/hh_member_note:label')"/>
      </input>
      <input appearance="hidden" ref="/data/person/type"/>
      <input appearance="hidden" ref="/data/person/parent"/>
      <input ref="/data/person/first_name">
        <label ref="jr:itext('/data/person/first_name:label')"/>
      </input>
      <input ref="/data/person/middle_name">
        <label ref="jr:itext('/data/person/middle_name:label')"/>
      </input>
      <input ref="/data/person/last_name">
        <label ref="jr:itext('/data/person/last_name:label')"/>
      </input>
      <input ref="/data/person/sex_note">
        <label ref="jr:itext('/data/person/sex_note:label')"/>
      </input>
      <select1 ref="/data/person/sex">
        <label ref="jr:itext('/data/person/sex:label')"/>
        <item>
          <label ref="jr:itext('/data/person/sex/male:label')"/>
          <value>male</value>
        </item>
        <item>
          <label ref="jr:itext('/data/person/sex/female:label')"/>
