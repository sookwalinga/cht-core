 selected( /pregnancy/pregnancy_issues_group/pregnancy_and_pallor/pallor ,&quot;yes&quot;),1,0)" nodeset="/pregnancy/pregnancy_issues_group/pregnancy_and_pallor/refer_pregnancy_complications" type="string"/>
