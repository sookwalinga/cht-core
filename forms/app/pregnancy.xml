      <bind calculate="if(selected( /pregnancy/pregnancy_issues_group/pregnancy_issues ,&quot;difficulty_breathing&quot;) or 
 selected( /pregnancy/pregnancy_issues_group/pregnancy_issues ,&quot;fatigue&quot;) or 
