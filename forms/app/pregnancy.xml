 selected( /pregnancy/danger_signs/danger_sign_unconsciouss ,'no') and 
 selected( /pregnancy/danger_signs/danger_sign_severe_headache ,'no') and 
 selected( /pregnancy/danger_signs/danger_sign_fever ,'no') and 
 selected( /pregnancy/danger_signs/danger_sign_abdominal_pain ,'no') and 
