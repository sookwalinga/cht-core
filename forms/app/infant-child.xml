      <instance>
        <infant-child delimiter="#" id="infant-child" prefix="J1!infant-child!">
          <inputs>
            <meta>
              <location>
                <lat/>
                <long/>
                <error/>
                <message/>
              </location>
            </meta>
            <child_consent/>
            <num_child_visits/>
            <user>
              <contact_id/>
              <facility_id/>
              <name/>
            </user>
            <contact>
              <name/>
              <sex/>
              <date_of_birth/>
            </contact>
          </inputs>
          <child_name/>
          <n_child_visits/>
          <previous_child_consent/>
          <child_date_of_birth/>
          <consent>
            <child_consent_today/>
          </consent>
          <child_visit_intro_note/>
          <first_visit_6_months>
            <delivery_location/>
            <child_card_available/>
            <birthweight_on_child_card/>
            <child_birthweight/>
            <child_size_birth/>
            <normal_baby_note/>
            <small_baby_note/>
            <has_received_small_baby_services/>
            <refer_small_baby_note/>
            <refer_flag_small_baby/>
            <encourage_small_baby_note/>
          </first_visit_6_months>
          <child_danger_signs>
            <danger_signs_intro_note/>
            <neonatal_screening>
              <neonatal_danger_signs/>
            </neonatal_screening>
          </child_danger_signs>
          <meta tag="hidden">
            <instanceID/>
          </meta>
        </infant-child>
      </instance>
      <instance id="contact-summary"/>
      <bind nodeset="/infant-child/inputs/child_consent" type="string"/>
      <bind nodeset="/infant-child/inputs/num_child_visits" type="string"/>
      <bind nodeset="/infant-child/inputs/user/contact_id" type="string"/>
      <bind nodeset="/infant-child/inputs/user/facility_id" type="string"/>
      <bind nodeset="/infant-child/inputs/user/name" type="string"/>
      <bind nodeset="/infant-child/inputs/contact/name" type="string"/>
      <bind nodeset="/infant-child/inputs/contact/sex" type="string"/>
      <bind nodeset="/infant-child/inputs/contact/date_of_birth" type="string"/>
      <bind calculate="../inputs/contact/name" nodeset="/infant-child/child_name" type="string"/>
      <bind calculate="../inputs/num_child_visits" nodeset="/infant-child/n_child_visits" type="string"/>
      <bind calculate="../inputs/child_consent" nodeset="/infant-child/previous_child_consent" type="string"/>
      <bind calculate="../inputs/contact/date_of_birth" nodeset="/infant-child/child_date_of_birth" type="string"/>
      <bind nodeset="/infant-child/consent" relevant=" /infant-child/n_child_visits =0"/>
      <bind nodeset="/infant-child/consent/child_consent_today" type="select1"/>
      <bind nodeset="/infant-child/child_visit_intro_note" readonly="true()" relevant="selected( /infant-child/inputs/child_consent ,&quot;yes&quot;)" type="string"/>
      <bind nodeset="/infant-child/first_visit_6_months" relevant=" /infant-child/n_child_visits =0 and  /infant-child/inputs/child_consent =&quot;yes&quot; and (decimal-date-time(today())-decimal-date-time( /infant-child/child_date_of_birth )) &lt; 182.5"/>
      <bind nodeset="/infant-child/first_visit_6_months/delivery_location" required="true()" type="select1"/>
      <bind nodeset="/infant-child/first_visit_6_months/child_card_available" required="true()" type="select1"/>
      <bind nodeset="/infant-child/first_visit_6_months/birthweight_on_child_card" relevant="selected( /infant-child/first_visit_6_months/child_card_available ,&quot;yes&quot;)" required="true()" type="select1"/>
      <bind constraint=". &gt;= 0.5 and . &lt;= 7" jr:constraintMsg="jr:itext('/infant-child/first_visit_6_months/child_birthweight:jr:constraintMsg')" nodeset="/infant-child/first_visit_6_months/child_birthweight" relevant="selected( /infant-child/first_visit_6_months/child_card_available ,&quot;yes&quot;) and selected( /infant-child/first_visit_6_months/birthweight_on_child_card ,&quot;yes&quot;)" required="true()" type="decimal"/>
      <bind nodeset="/infant-child/first_visit_6_months/child_size_birth" relevant="(selected( /infant-child/first_visit_6_months/birthweight_on_child_card ,&quot;no&quot;) or selected( /infant-child/first_visit_6_months/child_card_available ,&quot;no&quot;))" required="true()" type="select1"/>
      <bind nodeset="/infant-child/first_visit_6_months/normal_baby_note" readonly="true()" relevant=" /infant-child/first_visit_6_months/child_birthweight  &gt;= 2 or selected( /infant-child/first_visit_6_months/child_size_birth ,&quot;regular&quot;) or selected( /infant-child/first_visit_6_months/child_size_birth ,&quot;large&quot;)" type="string"/>
      <bind nodeset="/infant-child/first_visit_6_months/small_baby_note" readonly="true()" relevant=" /infant-child/first_visit_6_months/child_birthweight  &lt; 2 or selected( /infant-child/first_visit_6_months/child_size_birth ,&quot;small&quot;)" type="string"/>
      <bind nodeset="/infant-child/first_visit_6_months/has_received_small_baby_services" relevant=" /infant-child/first_visit_6_months/child_birthweight  &lt; 2 or selected( /infant-child/first_visit_6_months/child_size_birth ,&quot;small&quot;)" required="true()" type="select1"/>
      <bind nodeset="/infant-child/first_visit_6_months/refer_small_baby_note" readonly="true()" relevant="selected( /infant-child/first_visit_6_months/has_received_small_baby_services ,&quot;no&quot;)" type="string"/>
      <bind calculate="if(selected( /infant-child/first_visit_6_months/has_received_small_baby_services ,&quot;no&quot;),1,0)" nodeset="/infant-child/first_visit_6_months/refer_flag_small_baby" type="string"/>
      <bind nodeset="/infant-child/first_visit_6_months/encourage_small_baby_note" readonly="true()" relevant="selected( /infant-child/first_visit_6_months/has_received_small_baby_services ,&quot;yes&quot;)" type="string"/>
      <bind nodeset="/infant-child/child_danger_signs" relevant=" /infant-child/previous_child_consent =1 or  /infant-child/consent/child_consent_today =1"/>
      <bind nodeset="/infant-child/child_danger_signs/danger_signs_intro_note" readonly="true()" type="string"/>
      <bind nodeset="/infant-child/child_danger_signs/neonatal_screening" relevant="(decimal-date-time(today())-decimal-date-time( /infant-child/child_date_of_birth )) &lt;= 42"/>
      <bind nodeset="/infant-child/child_danger_signs/neonatal_screening/neonatal_danger_signs" required="true()" type="select"/>
      <bind calculate="concat('uuid:', uuid())" nodeset="/infant-child/meta/instanceID" readonly="true()" type="string"/>
    </model>
  </h:head>
  <h:body>
    <group appearance="hidden" ref="/infant-child/inputs">
