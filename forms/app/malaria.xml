      <instance id="contact-summary"/>
      <bind nodeset="/malaria/inputs" relevant="false()"/>
      <bind nodeset="/malaria/inputs/user/contact_id" type="string"/>
      <bind nodeset="/malaria/inputs/user/facility_id" type="string"/>
      <bind nodeset="/malaria/inputs/user/name" type="string"/>
      <bind nodeset="/malaria/inputs/contact/_id" type="db:person"/>
      <bind nodeset="/malaria/inputs/contact/name" type="string"/>
      <bind nodeset="/malaria/inputs/contact/date_of_birth" type="string"/>
      <bind nodeset="/malaria/client_name" type="string" calculate="../inputs/contact/name"/>
      <bind nodeset="/malaria/patient_id" type="string" calculate="../inputs/contact/_id"/>
      <bind nodeset="/malaria/created_by" type="string" calculate="../inputs/user/name"/>
      <bind nodeset="/malaria/created_by_person_uuid" type="string" calculate="../inputs/user/contact_id"/>
      <bind nodeset="/malaria/created_by_place_uuid" type="string" calculate="../inputs/user/facility_id"/>
      <bind nodeset="/malaria/date_of_birth_c" type="string" calculate="../inputs/contact/date_of_birth"/>
      <bind nodeset="/malaria/age_days" type="string" calculate="int(decimal-date-time(now())-decimal-date-time( /malaria/date_of_birth_c ))"/>
      <bind nodeset="/malaria/age_years" type="string" calculate="int( /malaria/age_days  div (30 *12),0)"/>
      <bind nodeset="/malaria/start" jr:preload="timestamp" type="dateTime" jr:preloadParams="start"/>
      <bind nodeset="/malaria/end" jr:preload="timestamp" type="dateTime" jr:preloadParams="end"/>
      <bind nodeset="/malaria/malaria/has_malaria_symptoms" type="select1" required="true()"/>
      <bind nodeset="/malaria/malaria/symptom_start_date_headache" type="date" required="true()" constraint=". &lt;= today()" jr:constraintMsg="jr:itext('/malaria/malaria/symptom_start_date_headache:jr:constraintMsg')" relevant="selected( /malaria/malaria/has_malaria_symptoms ,&quot;yes&quot;)"/>
      <bind nodeset="/malaria/malaria/went_to_facility_for_checkup" type="select1" required="true()" relevant="selected( /malaria/malaria/has_malaria_symptoms ,&quot;yes&quot;)"/>
      <bind nodeset="/malaria/malaria/malaria_results_from_facility" type="select1" required="true()" relevant="selected( /malaria/malaria/went_to_facility_for_checkup ,&quot;yes&quot;) and selected( /malaria/malaria/has_malaria_symptoms ,&quot;yes&quot;)"/>
      <bind nodeset="/malaria/malaria/note_test_client" readonly="true()" type="string" relevant="selected( /malaria/malaria/went_to_facility_for_checkup ,&quot;no&quot;) and selected( /malaria/malaria/has_malaria_symptoms ,&quot;yes&quot;)"/>
      <bind nodeset="/malaria/malaria/malaria_results_from_chv" type="select1" required="true()" relevant="selected( /malaria/malaria/went_to_facility_for_checkup ,&quot;no&quot;) and selected( /malaria/malaria/has_malaria_symptoms ,&quot;yes&quot;)"/>
      <bind nodeset="/malaria/malaria/malaria_positive_condition" type="select1" required="true()" relevant="selected( /malaria/malaria/malaria_results_from_chv ,&quot;positive&quot;) and selected( /malaria/malaria/has_malaria_symptoms ,&quot;yes&quot;)"/>
      <bind nodeset="/malaria/malaria/chv_provided_medication" type="select1" required="true()" relevant="selected( /malaria/malaria/malaria_positive_condition ,&quot;un-complicated&quot;) and selected( /malaria/malaria/has_malaria_symptoms ,&quot;yes&quot;)"/>
      <bind nodeset="/malaria/malaria/choose_malaria_dosage" type="select1" required="true()" relevant="selected( /malaria/malaria/malaria_positive_condition ,&quot;un-complicated&quot;) and selected( /malaria/malaria/chv_provided_medication ,&quot;yes&quot;) and selected( /malaria/malaria/has_malaria_symptoms ,&quot;yes&quot;)"/>
      <bind nodeset="/malaria/malaria/referral_given" type="select1" required="true()" relevant="selected( /malaria/malaria/malaria_positive_condition ,&quot;complicated&quot;) and selected( /malaria/malaria/has_malaria_symptoms ,&quot;yes&quot;)"/>
      <bind nodeset="/malaria/malaria/why_referral_not_given" type="string" required="true()" relevant="selected( /malaria/malaria/malaria_positive_condition ,&quot;complicated&quot;) and selected( /malaria/malaria/referral_given ,&quot;no&quot;) and selected( /malaria/malaria/has_malaria_symptoms ,&quot;yes&quot;)"/>
      <bind nodeset="/malaria/malaria/travelled_in_past_month" type="select1" required="true()"/>
      <bind nodeset="/malaria/malaria/client_profession" type="select1" required="true()" relevant="selected( /malaria/malaria/has_malaria_symptoms ,&quot;yes&quot;) or selected( /malaria/malaria/travelled_in_past_month ,&quot;yes&quot;)"/>
      <bind nodeset="/malaria/malaria/is_mosquito_net_used" type="select1" required="true()"/>
      <bind nodeset="/malaria/malaria/reasons_nets_unused" type="select1" required="true()" relevant="selected( /malaria/malaria/is_mosquito_net_used ,&quot;no&quot;)"/>
      <bind nodeset="/malaria/additional_services/was_additional_services_provided" type="select1" required="true()"/>
      <bind nodeset="/malaria/additional_services/services_provided" type="select1" relevant="selected( /malaria/additional_services/was_additional_services_provided ,&quot;yes&quot;)"/>
      <bind nodeset="/malaria/household_location/gps_note" readonly="true()" type="string"/>
      <bind nodeset="/malaria/household_location/gps" type="geopoint" required="true()"/>
      <bind nodeset="/malaria/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
    </model>
