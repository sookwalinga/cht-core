      <instance id="contact-summary"/>
      <bind nodeset="/covid_education/inputs" relevant="false()"/>
      <bind nodeset="/covid_education/inputs/user/contact_id" type="string"/>
      <bind nodeset="/covid_education/inputs/user/facility_id" type="string"/>
      <bind nodeset="/covid_education/inputs/user/name" type="string"/>
      <bind nodeset="/covid_education/inputs/contact/_id" type="db:person"/>
      <bind nodeset="/covid_education/created_by" type="string" calculate="../inputs/user/name"/>
      <bind nodeset="/covid_education/created_by_person_uuid" type="string" calculate="../inputs/user/contact_id"/>
      <bind nodeset="/covid_education/created_by_place_uuid" type="string" calculate="../inputs/user/facility_id"/>
      <bind nodeset="/covid_education/start" jr:preload="timestamp" type="dateTime" jr:preloadParams="start"/>
      <bind nodeset="/covid_education/end" jr:preload="timestamp" type="dateTime" jr:preloadParams="end"/>
      <bind nodeset="/covid_education/covid19_intro/covid19_intro_note" readonly="true()" type="string"/>
      <bind nodeset="/covid_education/corona_precautions/does_client_take_precautions" type="select1" required="true()"/>
      <bind nodeset="/covid_education/corona_precautions/precautions_taken" type="select" relevant="selected( /covid_education/corona_precautions/does_client_take_precautions ,&quot;yes&quot;)" required="true()"/>
      <bind nodeset="/covid_education/corona_precautions/congratulate_client" readonly="true()" type="string" relevant="selected( /covid_education/corona_precautions/precautions_taken ,&quot;regular_hand_wash&quot;) or selected( /covid_education/corona_precautions/precautions_taken ,&quot;avoid_gathering&quot;) or selected( /covid_education/corona_precautions/precautions_taken ,&quot;cover_mouth&quot;) or selected( /covid_education/corona_precautions/precautions_taken ,&quot;avoid_handshake&quot;) or selected( /covid_education/corona_precautions/precautions_taken ,&quot;avoid_face_touch&quot;) or selected( /covid_education/corona_precautions/precautions_taken ,&quot;avoid_unnecessary_travel&quot;) or selected( /covid_education/corona_precautions/precautions_taken ,&quot;hand_wash_before_home&quot;) or selected( /covid_education/corona_precautions/precautions_taken ,&quot;wear_mask&quot;) or selected( /covid_education/corona_precautions/precautions_taken ,&quot;other&quot;)"/>
      <bind nodeset="/covid_education/corona_precautions/read_precautions_to_client" readonly="true()" type="string" relevant="selected( /covid_education/corona_precautions/does_client_take_precautions ,&quot;no&quot;)"/>
      <bind nodeset="/covid_education/corona_signs/corona_signs_list" readonly="true()" type="string"/>
      <bind nodeset="/covid_education/corona_signs/age_above_50" type="select1" required="true()"/>
      <bind nodeset="/covid_education/corona_education/source_of_corona_education" type="select" required="true()"/>
      <bind nodeset="/covid_education/corona_education/source_of_corona_education_other" type="string" relevant="selected( /covid_education/corona_education/source_of_corona_education ,&quot;other&quot;)" required="true()"/>
      <bind nodeset="/covid_education/vulnerable_corona_group/list_of_vulnerable_group" readonly="true()" type="string"/>
      <bind nodeset="/covid_education/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
    </model>
