<?xml version="1.0"?>
<h:html xmlns="http://www.w3.org/2002/xforms" xmlns:h="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms">
  <h:head>
    <h:title>Group Session Planning</h:title>
    <model>
      <itext>
        <translation lang="en">
          <text id="/group_session_planning/group_meeting_details/planned_group_meeting_date:label">
            <value>When are you going to hold a community meeting in your area?</value>
          </text>
          <text id="/group_session_planning/group_meeting_details:label">
            <value>Supervision Details</value>
          </text>
          <text id="/group_session_planning/inputs/contact/_id:label">
            <value>Place ID</value>
          </text>
          <text id="/group_session_planning/inputs/contact/name:label">
            <value>Place Name</value>
          </text>
          <text id="/group_session_planning/inputs/place_uuid:label">
            <value>Place UUID</value>
          </text>
          <text id="/group_session_planning/inputs:label">
            <value>Inputs</value>
          </text>
        </translation>
      </itext>
      <instance>
        <group_session_planning id="group_session_planning" prefix="J1!group_session_planning!" delimiter="#" version="2022-05-13 08:35:52">
          <inputs>
            <meta>
              <location>
                <lat/>
                <long/>
                <error/>
                <message/>
              </location>
            </meta>
            <source/>
            <source_id/>
            <task_id/>
            <place_uuid/>
            <contact>
              <_id/>
              <name/>
            </contact>
          </inputs>
          <group_meeting_details>
            <planned_group_meeting_date/>
          </group_meeting_details>
          <meta tag="hidden">
            <instanceID/>
            <instanceName/>
          </meta>
        </group_session_planning>
      </instance>
      <instance id="contact-summary"/>
      <bind nodeset="/group_session_planning/inputs" relevant="./source='user'"/>
      <bind nodeset="/group_session_planning/inputs/source" type="string"/>
      <bind nodeset="/group_session_planning/inputs/source_id" type="string"/>
      <bind nodeset="/group_session_planning/inputs/task_id" type="string"/>
      <bind nodeset="/group_session_planning/inputs/place_uuid" type="string" calculate="../contact/_id"/>
      <bind nodeset="/group_session_planning/inputs/contact/_id" type="string"/>
      <bind nodeset="/group_session_planning/inputs/contact/name" type="string"/>
      <bind nodeset="/group_session_planning/group_meeting_details/planned_group_meeting_date" type="date" required="true()"/>
      <bind nodeset="/group_session_planning/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
      <bind nodeset="/group_session_planning/meta/instanceName" type="string" calculate="D-tree"/>
    </model>
  </h:head>
  <h:body>
    <group appearance="field-list" ref="/group_session_planning/inputs">
      <label ref="jr:itext('/group_session_planning/inputs:label')"/>
      <group ref="/group_session_planning/inputs/contact">
        <input appearance="select-contact type-person" ref="/group_session_planning/inputs/contact/_id">
          <label ref="jr:itext('/group_session_planning/inputs/contact/_id:label')"/>
        </input>
        <input appearance="hidden" ref="/group_session_planning/inputs/contact/name">
          <label ref="jr:itext('/group_session_planning/inputs/contact/name:label')"/>
        </input>
      </group>
    </group>
    <group appearance="field-list" ref="/group_session_planning/group_meeting_details">
      <label ref="jr:itext('/group_session_planning/group_meeting_details:label')"/>
      <input ref="/group_session_planning/group_meeting_details/planned_group_meeting_date">
        <label ref="jr:itext('/group_session_planning/group_meeting_details/planned_group_meeting_date:label')"/>
      </input>
    </group>
  </h:body>
</h:html>
