            <c_formatted_visit_date/>
            <r_planned_visit_date/>
            <c_formatted_task_date/>
            <r_followup_note/>
          </group_summary>
          <meta tag="hidden">
            <instanceID/>
            <instanceName/>
          </meta>
        </quality_monitoring_planning>
      </instance>
      <instance id="contact-summary"/>
      <bind nodeset="/quality_monitoring_planning/inputs" relevant="./source='user'"/>
      <bind nodeset="/quality_monitoring_planning/inputs/source" type="string"/>
      <bind nodeset="/quality_monitoring_planning/inputs/source_id" type="string"/>
      <bind nodeset="/quality_monitoring_planning/inputs/task_id" type="string"/>
      <bind calculate="../contact/_id" nodeset="/quality_monitoring_planning/inputs/patient_uuid" type="string"/>
      <bind calculate="../contact/patient_id" nodeset="/quality_monitoring_planning/inputs/patient_id" type="string"/>
      <bind nodeset="/quality_monitoring_planning/inputs/contact/_id" type="string"/>
      <bind nodeset="/quality_monitoring_planning/inputs/contact/patient_id" type="string"/>
      <bind nodeset="/quality_monitoring_planning/inputs/contact/name" type="string"/>
      <bind calculate="../inputs/contact/_id" nodeset="/quality_monitoring_planning/_id" type="string"/>
      <bind calculate="../inputs/contact/_id" nodeset="/quality_monitoring_planning/patient_id" type="string"/>
      <bind calculate="../inputs/contact/patient_id" nodeset="/quality_monitoring_planning/chw_id" type="string"/>
      <bind calculate="../inputs/contact/name" nodeset="/quality_monitoring_planning/chw_name" type="string"/>
      <bind constraint=". &gt; today()" jr:constraintMsg="jr:itext('/quality_monitoring_planning/visit_details/planned_visit_date:jr:constraintMsg')" nodeset="/quality_monitoring_planning/visit_details/planned_visit_date" required="true()" type="date"/>
      <bind nodeset="/quality_monitoring_planning/group_summary/r_chw_info_title" readonly="true()" type="string"/>
      <bind nodeset="/quality_monitoring_planning/group_summary/r_chw_info" readonly="true()" type="string"/>
      <bind nodeset="/quality_monitoring_planning/group_summary/r_followup" readonly="true()" type="string"/>
      <bind calculate="format-date( /quality_monitoring_planning/visit_details/planned_visit_date , '%a %e %b %Y')" nodeset="/quality_monitoring_planning/group_summary/c_formatted_visit_date" type="string"/>
      <bind nodeset="/quality_monitoring_planning/group_summary/r_planned_visit_date" readonly="true()" type="string"/>
      <bind calculate="format-date(date(decimal-date-time( /quality_monitoring_planning/visit_details/planned_visit_date ) - 2), '%a %e %b %Y')" nodeset="/quality_monitoring_planning/group_summary/c_formatted_task_date" type="string"/>
      <bind nodeset="/quality_monitoring_planning/group_summary/r_followup_note" readonly="true()" type="string"/>
      <bind calculate="concat('uuid:', uuid())" nodeset="/quality_monitoring_planning/meta/instanceID" readonly="true()" type="string"/>
      <bind calculate="D-tree" nodeset="/quality_monitoring_planning/meta/instanceName" type="string"/>
    </model>
  </h:head>
  <h:body class="pages">
    <group appearance="field-list" ref="/quality_monitoring_planning/inputs">
      <label ref="jr:itext('/quality_monitoring_planning/inputs:label')"/>
      <group ref="/quality_monitoring_planning/inputs/contact">
        <input appearance="select-contact type-person" ref="/quality_monitoring_planning/inputs/contact/_id">
          <label ref="jr:itext('/quality_monitoring_planning/inputs/contact/_id:label')"/>
        </input>
        <input appearance="hidden" ref="/quality_monitoring_planning/inputs/contact/patient_id">
          <label ref="jr:itext('/quality_monitoring_planning/inputs/contact/patient_id:label')"/>
        </input>
        <input appearance="hidden" ref="/quality_monitoring_planning/inputs/contact/name">
          <label ref="jr:itext('/quality_monitoring_planning/inputs/contact/name:label')"/>
        </input>
      </group>
    </group>
    <group appearance="field-list" ref="/quality_monitoring_planning/visit_details">
      <label ref="jr:itext('/quality_monitoring_planning/visit_details:label')"/>
      <input ref="/quality_monitoring_planning/visit_details/planned_visit_date">
        <label ref="jr:itext('/quality_monitoring_planning/visit_details/planned_visit_date:label')"/>
      </input>
    </group>
    <group appearance="field-list summary" ref="/quality_monitoring_planning/group_summary">
      <label ref="jr:itext('/quality_monitoring_planning/group_summary:label')"/>
      <input appearance="h2 blue" ref="/quality_monitoring_planning/group_summary/r_chw_info_title">
        <label ref="jr:itext('/quality_monitoring_planning/group_summary/r_chw_info_title:label')"/>
      </input>
      <input ref="/quality_monitoring_planning/group_summary/r_chw_info">
        <label ref="jr:itext('/quality_monitoring_planning/group_summary/r_chw_info:label')"/>
      </input>
      <input appearance="h2 red" ref="/quality_monitoring_planning/group_summary/r_followup">
        <label ref="jr:itext('/quality_monitoring_planning/group_summary/r_followup:label')"/>
      </input>
      <input ref="/quality_monitoring_planning/group_summary/r_planned_visit_date">
        <label ref="jr:itext('/quality_monitoring_planning/group_summary/r_planned_visit_date:label')"/>
      </input>
      <input ref="/quality_monitoring_planning/group_summary/r_followup_note">
        <label ref="jr:itext('/quality_monitoring_planning/group_summary/r_followup_note:label')"/>
      </input>
    </group>
  </h:body>
</h:html>
