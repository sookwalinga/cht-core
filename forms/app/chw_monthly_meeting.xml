      </input>
      <input appearance="multiline" ref="/chw_monthly_meeting/meeting_details/challenges">
        <label ref="jr:itext('/chw_monthly_meeting/meeting_details/challenges:label')"/>
      </input>
      <input ref="/chw_monthly_meeting/meeting_details/actions">
