          </next_meeting_details>
          <group_summary>
            <r_topics_covered_title/>
            <r_topics_covered/>
            <r_next_meeting_title/>
            <c_formatted_next_meeting_date/>
            <r_next_meeting/>
            <c_formatted_task_date/>
            <r_followup_note/>
          </group_summary>
          <meta tag="hidden">
            <instanceID/>
            <instanceName/>
          </meta>
        </chw_monthly_meeting>
      </instance>
      <instance id="contact-summary"/>
      <bind nodeset="/chw_monthly_meeting/inputs" relevant="./source='user'"/>
      <bind nodeset="/chw_monthly_meeting/inputs/source" type="string"/>
      <bind nodeset="/chw_monthly_meeting/inputs/source_id" type="string"/>
      <bind nodeset="/chw_monthly_meeting/inputs/task_id" type="string"/>
      <bind nodeset="/chw_monthly_meeting/inputs/contact/_id" type="string"/>
      <bind nodeset="/chw_monthly_meeting/inputs/contact/patient_id" type="string"/>
      <bind nodeset="/chw_monthly_meeting/inputs/contact/patient_uuid" type="string"/>
      <bind nodeset="/chw_monthly_meeting/inputs/contact/place_id" type="string"/>
      <bind nodeset="/chw_monthly_meeting/inputs/contact/name" type="string"/>
      <bind calculate="../inputs/contact/_id" nodeset="/chw_monthly_meeting/_id" type="string"/>
      <bind calculate="../inputs/contact/_id" nodeset="/chw_monthly_meeting/patient_id" type="string"/>
      <bind calculate="../inputs/contact/_id" nodeset="/chw_monthly_meeting/place_id" type="string"/>
      <bind calculate="../inputs/contact/name" nodeset="/chw_monthly_meeting/place_name" type="string"/>
      <bind calculate="instance('contact-summary')/context/lastest_monthly_meeting_topic" nodeset="/chw_monthly_meeting/latest_monthly_meeting_topic" type="string"/>
      <bind calculate="instance('contact-summary')/context/latest_monthly_meeting_date" nodeset="/chw_monthly_meeting/latest_monthly_meeting_date" type="string"/>
      <bind calculate="instance('contact-summary')/context/latest_monthly_meeting_absentees" nodeset="/chw_monthly_meeting/latest_monthly_meeting_absentees" type="string"/>
      <bind jr:preload="timestamp" jr:preloadParams="start" nodeset="/chw_monthly_meeting/start" type="dateTime"/>
      <bind jr:preload="timestamp" jr:preloadParams="end" nodeset="/chw_monthly_meeting/end" type="dateTime"/>
      <bind nodeset="/chw_monthly_meeting/prev_meeting" relevant="string-length( /chw_monthly_meeting/latest_monthly_meeting_date ) &gt; 0"/>
      <bind nodeset="/chw_monthly_meeting/prev_meeting/meeting_date" readonly="true()" type="string"/>
      <bind nodeset="/chw_monthly_meeting/prev_meeting/meeting_topic" readonly="true()" type="string"/>
      <bind nodeset="/chw_monthly_meeting/prev_meeting/absentees" readonly="true()" type="string"/>
      <bind nodeset="/chw_monthly_meeting/planned_meeting/meeting_option" required="true()" type="select1"/>
      <bind nodeset="/chw_monthly_meeting/meeting_details" relevant="selected( /chw_monthly_meeting/planned_meeting/meeting_option , 'now')"/>
      <bind constraint=". &gt;= 0" jr:constraintMsg="jr:itext('/chw_monthly_meeting/meeting_details/attended:jr:constraintMsg')" nodeset="/chw_monthly_meeting/meeting_details/attended" required="true()" type="int"/>
      <bind constraint=". &gt;=0" jr:constraintMsg="jr:itext('/chw_monthly_meeting/meeting_details/not_attended:jr:constraintMsg')" nodeset="/chw_monthly_meeting/meeting_details/not_attended" required="true()" type="int"/>
      <bind calculate=" /chw_monthly_meeting/meeting_details/not_attended " nodeset="/chw_monthly_meeting/meeting_details/absent_chvs_count" readonly="true()" type="string"/>
      <bind nodeset="/chw_monthly_meeting/meeting_details/absent_chvs" relevant=" /chw_monthly_meeting/meeting_details/not_attended  &gt; 0" required="true()"/>
      <bind nodeset="/chw_monthly_meeting/meeting_details/absent_chvs/absent_chv" type="string"/>
      <bind nodeset="/chw_monthly_meeting/meeting_details/absent_chvs/name" type="string"/>
      <bind nodeset="/chw_monthly_meeting/meeting_details/topics" required="true()" type="string"/>
      <bind nodeset="/chw_monthly_meeting/meeting_details/challenges" required="true()" type="string"/>
      <bind nodeset="/chw_monthly_meeting/meeting_details/actions" required="true()" type="string"/>
      <bind constraint=". &gt; today()" jr:constraintMsg="jr:itext('/chw_monthly_meeting/next_meeting_details/next_meeting_date:jr:constraintMsg')" nodeset="/chw_monthly_meeting/next_meeting_details/next_meeting_date" required="true()" type="date"/>
      <bind nodeset="/chw_monthly_meeting/group_summary/r_topics_covered_title" readonly="true()" relevant="selected( /chw_monthly_meeting/planned_meeting/meeting_option , 'now')" type="string"/>
      <bind nodeset="/chw_monthly_meeting/group_summary/r_topics_covered" readonly="true()" relevant="selected( /chw_monthly_meeting/planned_meeting/meeting_option , 'now')" type="string"/>
      <bind nodeset="/chw_monthly_meeting/group_summary/r_next_meeting_title" readonly="true()" type="string"/>
      <bind calculate="format-date( /chw_monthly_meeting/next_meeting_details/next_meeting_date , '%a %e %b %Y')" nodeset="/chw_monthly_meeting/group_summary/c_formatted_next_meeting_date" type="string"/>
      <bind nodeset="/chw_monthly_meeting/group_summary/r_next_meeting" readonly="true()" type="string"/>
      <bind calculate="format-date(date(decimal-date-time( /chw_monthly_meeting/next_meeting_details/next_meeting_date ) - 3), '%a %e %b %Y')" nodeset="/chw_monthly_meeting/group_summary/c_formatted_task_date" type="string"/>
      <bind nodeset="/chw_monthly_meeting/group_summary/r_followup_note" readonly="true()" type="string"/>
      <bind calculate="concat('uuid:', uuid())" nodeset="/chw_monthly_meeting/meta/instanceID" readonly="true()" type="string"/>
      <bind calculate="D-tree" nodeset="/chw_monthly_meeting/meta/instanceName" type="string"/>
    </model>
  </h:head>
