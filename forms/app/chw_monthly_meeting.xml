                <lat/>
                <long/>
                <error/>
                <message/>
              </location>
            </meta>
            <source/>
            <source_id/>
            <task_id/>
            <contact>
              <_id/>
              <patient_id/>
              <patient_uuid/>
              <place_id/>
              <name/>
            </contact>
          </inputs>
          <_id/>
          <patient_id/>
          <place_id/>
          <place_name/>
          <latest_monthly_meeting_topic/>
          <latest_monthly_meeting_date/>
          <latest_monthly_meeting_absentees/>
          <start/>
          <end/>
