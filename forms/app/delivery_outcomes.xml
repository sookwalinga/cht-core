      <instance>
        <delivery_outcomes delimiter="#" id="delivery_outcomes" prefix="J1!delivery_outcomes!" version="2019-04-25 00:00:00">
          <inputs>
            <meta>
              <location>
                <lat/>
                <long/>
                <error/>
                <message/>
              </location>
            </meta>
            <user>
              <contact_id/>
              <facility_id/>
              <name/>
              <EDD/>
            </user>
            <contact>
              <_id/>
              <name/>
              <sex/>
              <date_of_birth/>
            </contact>
          </inputs>
          <patient_id/>
          <client_name/>
          <client_date_of_birth/>
          <age_days/>
          <age_months/>
          <age_years/>
          <age_days_display/>
          <household_head/>
          <house_number/>
          <kitongoji/>
          <phone/>
          <client_EDD/>
          <week/>
          <month/>
          <client_information>
            <intro_note/>
            <household_note/>
            <phone_note/>
          </client_information>
          <confirm_delivery>
            <did_deliver/>
          </confirm_delivery>
          <number_deliveries>
            <check_multiple_deliveries/>
            <num_babies_delivered/>
            <live_birth/>
            <num_live_births/>
          </number_deliveries>
          <child_death_count/>
          <child_death_data_count/>
          <child_death_data jr:template="">
            <child_death_before_after_birth/>
            <child_date_of_death/>
            <miscarriage_or_stillbirth/>
          </child_death_data>
          <child_repeat_count/>
          <intro_data_capture>
            <child_data_note/>
            <multiple_child_data_note/>
          </intro_data_capture>
          <child_count/>
          <child jr:template="">
            <child_document_creation/>
          </child>
          <meta tag="hidden">
            <instanceID/>
          </meta>
        </delivery_outcomes>
      </instance>
      <instance id="contact-summary"/>
      <bind nodeset="/delivery_outcomes/inputs" relevant="./source = 'user'"/>
      <bind nodeset="/delivery_outcomes/inputs/user/contact_id" type="string"/>
      <bind nodeset="/delivery_outcomes/inputs/user/facility_id" type="string"/>
      <bind nodeset="/delivery_outcomes/inputs/user/name" type="string"/>
      <bind nodeset="/delivery_outcomes/inputs/user/EDD" type="string"/>
      <bind nodeset="/delivery_outcomes/inputs/contact/_id" type="db:person"/>
      <bind nodeset="/delivery_outcomes/inputs/contact/name" type="string"/>
      <bind nodeset="/delivery_outcomes/inputs/contact/sex" type="string"/>
      <bind nodeset="/delivery_outcomes/inputs/contact/date_of_birth" type="string"/>
      <bind calculate="../inputs/contact/_id" nodeset="/delivery_outcomes/patient_id" type="string"/>
      <bind calculate="../inputs/contact/name" nodeset="/delivery_outcomes/client_name" type="string"/>
      <bind calculate="../inputs/contact/date_of_birth" nodeset="/delivery_outcomes/client_date_of_birth" type="string"/>
      <bind calculate="int(decimal-date-time(now())-decimal-date-time( /delivery_outcomes/client_date_of_birth ))" nodeset="/delivery_outcomes/age_days" type="string"/>
      <bind calculate="int(( /delivery_outcomes/age_days  - ( /delivery_outcomes/age_years  * 12 * 30)) div 30,0)" nodeset="/delivery_outcomes/age_months" type="string"/>
      <bind calculate="int( /delivery_outcomes/age_days  div (30 *12),0)" nodeset="/delivery_outcomes/age_years" type="string"/>
      <bind calculate=" /delivery_outcomes/age_days  - ( /delivery_outcomes/age_months  * 30) - ( /delivery_outcomes/age_years  *12*30)" nodeset="/delivery_outcomes/age_days_display" type="string"/>
      <bind calculate="instance('contact-summary')/context/household_head" nodeset="/delivery_outcomes/household_head" type="string"/>
      <bind calculate="instance('contact-summary')/context/house_number" nodeset="/delivery_outcomes/house_number" type="string"/>
      <bind calculate="instance('contact-summary')/context/kitongoji" nodeset="/delivery_outcomes/kitongoji" type="string"/>
      <bind calculate="instance('contact-summary')/context/phone" nodeset="/delivery_outcomes/phone" type="string"/>
      <bind calculate="today()" nodeset="/delivery_outcomes/client_EDD" type="string"/>
      <bind calculate="7" nodeset="/delivery_outcomes/week" type="string"/>
      <bind calculate="30" nodeset="/delivery_outcomes/month" type="string"/>
      <bind nodeset="/delivery_outcomes/client_information/intro_note" readonly="true()" type="string"/>
      <bind nodeset="/delivery_outcomes/client_information/household_note" readonly="true()" type="string"/>
      <bind nodeset="/delivery_outcomes/client_information/phone_note" readonly="true()" type="string"/>
      <bind nodeset="/delivery_outcomes/confirm_delivery/did_deliver" required="true()" type="select1"/>
      <bind nodeset="/delivery_outcomes/number_deliveries" relevant="selected( /delivery_outcomes/confirm_delivery/did_deliver ,&quot;yes&quot;)"/>
      <bind nodeset="/delivery_outcomes/number_deliveries/check_multiple_deliveries" required="true()" type="select1"/>
      <bind constraint="2 &lt;= . and . &lt;= 4" jr:constraintMsg="jr:itext('/delivery_outcomes/number_deliveries/num_babies_delivered:jr:constraintMsg')" nodeset="/delivery_outcomes/number_deliveries/num_babies_delivered" relevant="selected( /delivery_outcomes/number_deliveries/check_multiple_deliveries ,&quot;more&quot;)" required="true()" type="int"/>
      <bind nodeset="/delivery_outcomes/number_deliveries/live_birth" relevant="selected( /delivery_outcomes/number_deliveries/check_multiple_deliveries ,&quot;one&quot;)" required="true()" type="select1"/>
      <bind constraint="0 &lt;= . and . &lt;=  /delivery_outcomes/number_deliveries/num_babies_delivered " jr:constraintMsg="jr:itext('/delivery_outcomes/number_deliveries/num_live_births:jr:constraintMsg')" nodeset="/delivery_outcomes/number_deliveries/num_live_births" relevant="selected( /delivery_outcomes/number_deliveries/check_multiple_deliveries ,&quot;more&quot;)" required="true()" type="int"/>
      <bind calculate="if(selected( /delivery_outcomes/number_deliveries/check_multiple_deliveries ,&quot;one&quot;) and selected( /delivery_outcomes/number_deliveries/live_birth ,&quot;yes&quot;),
 0,
 if(selected( /delivery_outcomes/number_deliveries/check_multiple_deliveries ,&quot;one&quot;) and selected( /delivery_outcomes/number_deliveries/live_birth ,&quot;no&quot;),
 1,
  /delivery_outcomes/number_deliveries/num_babies_delivered  -  /delivery_outcomes/number_deliveries/num_live_births ))" nodeset="/delivery_outcomes/child_death_count" type="string"/>
      <bind calculate=" /delivery_outcomes/child_death_count " nodeset="/delivery_outcomes/child_death_data_count" readonly="true()" type="string"/>
      <bind nodeset="/delivery_outcomes/child_death_data" relevant="selected( /delivery_outcomes/confirm_delivery/did_deliver ,&quot;yes&quot;) and  /delivery_outcomes/child_death_count  &gt; 0"/>
      <bind nodeset="/delivery_outcomes/child_death_data/child_death_before_after_birth" required="true()" type="select1"/>
      <bind constraint="(decimal-date-time(today()) - ( /delivery_outcomes/month  * 6)) &lt;= decimal-date-time(.) and decimal-date-time(.) &lt;= decimal-date-time(today())" jr:constraintMsg="jr:itext('/delivery_outcomes/child_death_data/child_date_of_death:jr:constraintMsg')" nodeset="/delivery_outcomes/child_death_data/child_date_of_death" relevant="selected( /delivery_outcomes/child_death_data/child_death_before_after_birth ,&quot;no&quot;)" required="true()" type="date"/>
      <bind calculate="if((decimal-date-time( /delivery_outcomes/client_EDD ) - decimal-date-time( /delivery_outcomes/child_death_data/child_date_of_death )) &gt; ( /delivery_outcomes/week  * 12), &quot;miscarriage&quot;, &quot;stillbirth&quot;)" nodeset="/delivery_outcomes/child_death_data/miscarriage_or_stillbirth" type="string"/>
      <bind calculate="if(selected( /delivery_outcomes/number_deliveries/check_multiple_deliveries ,&quot;one&quot;) and selected( /delivery_outcomes/number_deliveries/live_birth ,&quot;yes&quot;),1,if(selected( /delivery_outcomes/number_deliveries/check_multiple_deliveries ,&quot;one&quot;) and selected( /delivery_outcomes/number_deliveries/live_birth ,&quot;no&quot;),0, /delivery_outcomes/number_deliveries/num_live_births ))" nodeset="/delivery_outcomes/child_repeat_count" type="string"/>
      <bind nodeset="/delivery_outcomes/intro_data_capture" relevant="selected( /delivery_outcomes/confirm_delivery/did_deliver ,&quot;yes&quot;) and  /delivery_outcomes/child_repeat_count  &gt; 0"/>
      <bind nodeset="/delivery_outcomes/intro_data_capture/child_data_note" readonly="true()" relevant="selected( /delivery_outcomes/number_deliveries/check_multiple_deliveries ,&quot;one&quot;)" type="string"/>
      <bind nodeset="/delivery_outcomes/intro_data_capture/multiple_child_data_note" readonly="true()" relevant="selected( /delivery_outcomes/number_deliveries/check_multiple_deliveries ,&quot;more&quot;)" type="string"/>
      <bind calculate=" /delivery_outcomes/child_repeat_count " nodeset="/delivery_outcomes/child_count" readonly="true()" type="string"/>
      <bind nodeset="/delivery_outcomes/child" relevant="selected( /delivery_outcomes/confirm_delivery/did_deliver ,&quot;yes&quot;) and  /delivery_outcomes/child_repeat_count  &gt; 0"/>
      <bind calculate="concat('uuid:', uuid())" nodeset="/delivery_outcomes/meta/instanceID" readonly="true()" type="string"/>
    </model>
  </h:head>
