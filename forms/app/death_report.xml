      <instance>
        <death_report delimiter="#" id="death_report" prefix="J1!death_report!" version="2019-10-24_11-11">
          <inputs>
            <meta>
              <location>
                <lat/>
                <long/>
                <error/>
                <message/>
              </location>
            </meta>
            <user>
              <contact_id/>
              <facility_id/>
              <name/>
            </user>
            <contact>
              <date_of_birth/>
              <_id/>
              <name/>
              <sex/>
            </contact>
          </inputs>
          <client_name/>
          <patient_id/>
          <date_of_birth_c/>
          <sex_c/>
          <created_by/>
          <created_by_person_uuid/>
          <created_by_place_uuid/>
          <age_days/>
          <age_months/>
          <age_years/>
          <age_in_years/>
          <age_days_display/>
          <household_head/>
          <house_number/>
          <kitongoji/>
          <phone/>
          <client_information>
            <intro_note/>
            <household_note/>
            <phone_note/>
          </client_information>
          <death_report_intro>
            <intro/>
            <reason_death/>
          </death_report_intro>
          <suspected_maternal_death>
            <date_of_death_maternal/>
            <where_death/>
            <was_pregnant/>
            <during_childbirth/>
            <two_to_three_mo_after_pregnancy_childbirth/>
          </suspected_maternal_death>
          <next_of_kin>
            <next_of_kin_name/>
            <next_of_kin_rel_w_deceased/>
            <next_of_kin_street_shehia/>
            <next_of_kin_district/>
            <next_of_kin_phone/>
          </next_of_kin>
          <other>
            <date_of_death_other/>
          </other>
          <meta tag="hidden">
            <instanceID/>
          </meta>
        </death_report>
      </instance>
      <instance id="contact-summary"/>
      <bind nodeset="/death_report/inputs" relevant="false()"/>
      <bind nodeset="/death_report/inputs/user/contact_id" type="string"/>
      <bind nodeset="/death_report/inputs/user/facility_id" type="string"/>
      <bind nodeset="/death_report/inputs/user/name" type="string"/>
      <bind nodeset="/death_report/inputs/contact/date_of_birth" type="string"/>
      <bind nodeset="/death_report/inputs/contact/_id" type="db:person"/>
      <bind nodeset="/death_report/inputs/contact/name" type="string"/>
      <bind nodeset="/death_report/inputs/contact/sex" type="string"/>
      <bind calculate="../inputs/contact/name" nodeset="/death_report/client_name" type="string"/>
      <bind calculate="../inputs/contact/_id" nodeset="/death_report/patient_id" type="string"/>
      <bind calculate="../inputs/contact/date_of_birth" nodeset="/death_report/date_of_birth_c" type="string"/>
      <bind calculate="../inputs/contact/sex" nodeset="/death_report/sex_c" type="string"/>
      <bind calculate="../inputs/user/name" nodeset="/death_report/created_by" type="string"/>
      <bind calculate="../inputs/user/contact_id" nodeset="/death_report/created_by_person_uuid" type="string"/>
      <bind calculate="../inputs/user/facility_id" nodeset="/death_report/created_by_place_uuid" type="string"/>
      <bind calculate="int(decimal-date-time(now())-decimal-date-time( /death_report/date_of_birth_c ))" nodeset="/death_report/age_days" type="string"/>
      <bind calculate="int(( /death_report/age_days  - ( /death_report/age_years  * 12 * 30)) div 30,0)" nodeset="/death_report/age_months" type="string"/>
      <bind calculate="int( /death_report/age_days  div (30 *12),0)" nodeset="/death_report/age_years" type="string"/>
      <bind calculate="round((decimal-date-time(today()) - decimal-date-time( /death_report/date_of_birth_c )) div 365,0)" nodeset="/death_report/age_in_years" type="string"/>
      <bind calculate=" /death_report/age_days  - ( /death_report/age_months  * 30) - ( /death_report/age_years  *12*30)" nodeset="/death_report/age_days_display" type="string"/>
      <bind calculate="instance('contact-summary')/context/household_head" nodeset="/death_report/household_head" type="string"/>
      <bind calculate="instance('contact-summary')/context/house_number" nodeset="/death_report/house_number" type="string"/>
      <bind calculate="instance('contact-summary')/context/kitongoji" nodeset="/death_report/kitongoji" type="string"/>
      <bind calculate="instance('contact-summary')/context/phone" nodeset="/death_report/phone" type="string"/>
      <bind nodeset="/death_report/client_information/intro_note" readonly="true()" type="string"/>
      <bind nodeset="/death_report/client_information/household_note" readonly="true()" type="string"/>
      <bind nodeset="/death_report/client_information/phone_note" readonly="true()" type="string"/>
      <bind nodeset="/death_report/death_report_intro/intro" readonly="true()" type="string"/>
      <bind nodeset="/death_report/death_report_intro/reason_death" relevant=" /death_report/inputs/contact/sex  = &quot;female&quot; and  /death_report/age_in_years  &gt;= 12" required="true()" type="select1"/>
      <bind nodeset="/death_report/suspected_maternal_death" relevant=" /death_report/inputs/contact/sex  = &quot;female&quot; and  /death_report/age_in_years  &gt;= 12 and  /death_report/death_report_intro/reason_death  = &quot;pregnancy_delivery&quot;"/>
      <bind constraint=". &lt;= date-time(decimal-date-time(today())) and . &gt;= date-time(decimal-date-time( /death_report/date_of_birth_c ))" jr:constraintMsg="jr:itext('/death_report/suspected_maternal_death/date_of_death_maternal:jr:constraintMsg')" nodeset="/death_report/suspected_maternal_death/date_of_death_maternal" required="true()" type="date"/>
      <bind nodeset="/death_report/suspected_maternal_death/where_death" required="true()" type="select1"/>
      <bind nodeset="/death_report/suspected_maternal_death/was_pregnant" required="true()" type="select1"/>
      <bind nodeset="/death_report/suspected_maternal_death/during_childbirth" required="true()" type="select1"/>
      <bind nodeset="/death_report/suspected_maternal_death/two_to_three_mo_after_pregnancy_childbirth" required="true()" type="select1"/>
      <bind nodeset="/death_report/next_of_kin" relevant=" /death_report/inputs/contact/sex  = &quot;female&quot; and  /death_report/age_in_years  &gt;= 12 and  /death_report/death_report_intro/reason_death  = &quot;pregnancy_delivery&quot;"/>
      <bind constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2" jr:constraintMsg="jr:itext('/death_report/next_of_kin/next_of_kin_name:jr:constraintMsg')" nodeset="/death_report/next_of_kin/next_of_kin_name" required="true()" type="string"/>
      <bind constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2" jr:constraintMsg="jr:itext('/death_report/next_of_kin/next_of_kin_rel_w_deceased:jr:constraintMsg')" nodeset="/death_report/next_of_kin/next_of_kin_rel_w_deceased" required="true()" type="string"/>
      <bind constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2" jr:constraintMsg="jr:itext('/death_report/next_of_kin/next_of_kin_street_shehia:jr:constraintMsg')" nodeset="/death_report/next_of_kin/next_of_kin_street_shehia" required="true()" type="string"/>
      <bind constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2" jr:constraintMsg="jr:itext('/death_report/next_of_kin/next_of_kin_district:jr:constraintMsg')" nodeset="/death_report/next_of_kin/next_of_kin_district" required="true()" type="string"/>
      <bind constraint="regex(.,'^0[0-9]{9}$')" jr:constraintMsg="jr:itext('/death_report/next_of_kin/next_of_kin_phone:jr:constraintMsg')" nodeset="/death_report/next_of_kin/next_of_kin_phone" required="true()" type="string"/>
      <bind nodeset="/death_report/other" relevant="not( /death_report/inputs/contact/sex  = &quot;female&quot; and  /death_report/age_in_years  &gt;= 12 and  /death_report/death_report_intro/reason_death  = &quot;pregnancy_delivery&quot;)"/>
      <bind constraint=". &lt;= date-time(decimal-date-time(today())) and . &gt;= date-time(decimal-date-time( /death_report/date_of_birth_c ))" jr:constraintMsg="jr:itext('/death_report/other/date_of_death_other:jr:constraintMsg')" nodeset="/death_report/other/date_of_death_other" required="true()" type="date"/>
      <bind calculate="concat('uuid:', uuid())" nodeset="/death_report/meta/instanceID" readonly="true()" type="string"/>
    </model>
  </h:head>
  <h:body class="pages">
    <group ref="/death_report/inputs">
