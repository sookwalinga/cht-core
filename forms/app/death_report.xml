      <instance id="contact-summary"/>
      <bind nodeset="/death_report/inputs" relevant="false()"/>
      <bind nodeset="/death_report/inputs/user/contact_id" type="string"/>
      <bind nodeset="/death_report/inputs/user/facility_id" type="string"/>
      <bind nodeset="/death_report/inputs/user/name" type="string"/>
      <bind nodeset="/death_report/inputs/contact/date_of_birth" type="string"/>
      <bind nodeset="/death_report/inputs/contact/_id" type="db:person"/>
      <bind nodeset="/death_report/inputs/contact/name" type="string"/>
      <bind nodeset="/death_report/inputs/contact/sex" type="string"/>
      <bind nodeset="/death_report/client_name" type="string" calculate="../inputs/contact/name"/>
      <bind nodeset="/death_report/patient_id" type="string" calculate="../inputs/contact/_id"/>
      <bind nodeset="/death_report/date_of_birth_c" type="string" calculate="../inputs/contact/date_of_birth"/>
      <bind nodeset="/death_report/sex_c" type="string" calculate="../inputs/contact/sex"/>
      <bind nodeset="/death_report/created_by" type="string" calculate="../inputs/user/name"/>
      <bind nodeset="/death_report/created_by_person_uuid" type="string" calculate="../inputs/user/contact_id"/>
      <bind nodeset="/death_report/created_by_place_uuid" type="string" calculate="../inputs/user/facility_id"/>
      <bind nodeset="/death_report/age_days" type="string" calculate="int(decimal-date-time(now())-decimal-date-time( /death_report/date_of_birth_c ))"/>
      <bind nodeset="/death_report/age_months" type="string" calculate="int(( /death_report/age_days  - ( /death_report/age_years  * 12 * 30)) div 30,0)"/>
      <bind nodeset="/death_report/age_years" type="string" calculate="int( /death_report/age_days  div (30 *12),0)"/>
      <bind nodeset="/death_report/age_in_years" type="string" calculate="round((decimal-date-time(today()) - decimal-date-time( /death_report/date_of_birth_c )) div 365,0)"/>
      <bind nodeset="/death_report/age_days_display" type="string" calculate=" /death_report/age_days  - ( /death_report/age_months  * 30) - ( /death_report/age_years  *12*30)"/>
      <bind nodeset="/death_report/household_head" type="string" calculate="instance('contact-summary')/context/household_head"/>
      <bind nodeset="/death_report/house_number" type="string" calculate="instance('contact-summary')/context/house_number"/>
      <bind nodeset="/death_report/kitongoji" type="string" calculate="instance('contact-summary')/context/kitongoji"/>
      <bind nodeset="/death_report/phone" type="string" calculate="instance('contact-summary')/context/phone"/>
      <bind nodeset="/death_report/start" jr:preload="timestamp" type="dateTime" jr:preloadParams="start"/>
      <bind nodeset="/death_report/end" jr:preload="timestamp" type="dateTime" jr:preloadParams="end"/>
      <bind nodeset="/death_report/covid19_intro/covid19_intro_note" readonly="true()" type="string"/>
      <bind nodeset="/death_report/client_information/intro_note" readonly="true()" type="string"/>
      <bind nodeset="/death_report/client_information/household_note" readonly="true()" type="string"/>
      <bind nodeset="/death_report/client_information/phone_note" readonly="true()" type="string"/>
      <bind nodeset="/death_report/death_report_intro/intro" readonly="true()" type="string"/>
      <bind nodeset="/death_report/death_report_intro/reason_death" type="select1" required="true()" relevant=" /death_report/inputs/contact/sex  = &quot;female&quot; and  /death_report/age_in_years  &gt;= 12"/>
      <bind nodeset="/death_report/suspected_maternal_death" relevant=" /death_report/inputs/contact/sex  = &quot;female&quot; and  /death_report/age_in_years  &gt;= 12 and  /death_report/death_report_intro/reason_death  = &quot;pregnancy_delivery&quot;"/>
      <bind nodeset="/death_report/suspected_maternal_death/date_of_death_maternal" type="date" required="true()" constraint=". &lt;= date-time(decimal-date-time(today())) and . &gt;= date-time(decimal-date-time( /death_report/date_of_birth_c ))" jr:constraintMsg="jr:itext('/death_report/suspected_maternal_death/date_of_death_maternal:jr:constraintMsg')"/>
      <bind nodeset="/death_report/suspected_maternal_death/where_death" type="select1" required="true()"/>
      <bind nodeset="/death_report/suspected_maternal_death/was_pregnant" type="select1" required="true()"/>
      <bind nodeset="/death_report/suspected_maternal_death/during_childbirth" type="select1" required="true()"/>
      <bind nodeset="/death_report/suspected_maternal_death/two_to_three_mo_after_pregnancy_childbirth" type="select1" required="true()"/>
      <bind nodeset="/death_report/next_of_kin" relevant=" /death_report/inputs/contact/sex  = &quot;female&quot; and  /death_report/age_in_years  &gt;= 12 and  /death_report/death_report_intro/reason_death  = &quot;pregnancy_delivery&quot;"/>
      <bind nodeset="/death_report/next_of_kin/next_of_kin_name" type="string" required="true()" constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2" jr:constraintMsg="jr:itext('/death_report/next_of_kin/next_of_kin_name:jr:constraintMsg')"/>
      <bind nodeset="/death_report/next_of_kin/next_of_kin_rel_w_deceased" type="string" required="true()" constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2" jr:constraintMsg="jr:itext('/death_report/next_of_kin/next_of_kin_rel_w_deceased:jr:constraintMsg')"/>
      <bind nodeset="/death_report/next_of_kin/next_of_kin_street_shehia" type="string" required="true()" constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2" jr:constraintMsg="jr:itext('/death_report/next_of_kin/next_of_kin_street_shehia:jr:constraintMsg')"/>
      <bind nodeset="/death_report/next_of_kin/next_of_kin_district" type="string" required="true()" constraint="string-length(translate(.,&quot; &quot;,&quot;&quot;)) &gt;= 2" jr:constraintMsg="jr:itext('/death_report/next_of_kin/next_of_kin_district:jr:constraintMsg')"/>
      <bind nodeset="/death_report/next_of_kin/next_of_kin_phone" type="string" required="true()" constraint="regex(.,'^0[0-9]{9}$')" jr:constraintMsg="jr:itext('/death_report/next_of_kin/next_of_kin_phone:jr:constraintMsg')"/>
      <bind nodeset="/death_report/other" relevant="not( /death_report/inputs/contact/sex  = &quot;female&quot; and  /death_report/age_in_years  &gt;= 12 and  /death_report/death_report_intro/reason_death  = &quot;pregnancy_delivery&quot;)"/>
      <bind nodeset="/death_report/other/date_of_death_other" type="date" required="true()" constraint=". &lt;= date-time(decimal-date-time(today())) and . &gt;= date-time(decimal-date-time( /death_report/date_of_birth_c ))" jr:constraintMsg="jr:itext('/death_report/other/date_of_death_other:jr:constraintMsg')"/>
      <bind nodeset="/death_report/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
    </model>
  </h:head>
  <h:body class="pages">
    <group ref="/death_report/inputs">
      <group ref="/death_report/inputs/user">
        <input ref="/death_report/inputs/user/contact_id">
          <label ref="jr:itext('/death_report/inputs/user/contact_id:label')"/>
        </input>
        <input ref="/death_report/inputs/user/facility_id">
          <label ref="jr:itext('/death_report/inputs/user/facility_id:label')"/>
        </input>
        <input ref="/death_report/inputs/user/name">
          <label ref="jr:itext('/death_report/inputs/user/name:label')"/>
        </input>
      </group>
      <group ref="/death_report/inputs/contact">
        <input ref="/death_report/inputs/contact/date_of_birth"/>
        <input appearance="db-object" ref="/death_report/inputs/contact/_id"/>
        <input ref="/death_report/inputs/contact/name"/>
        <input ref="/death_report/inputs/contact/sex"/>
      </group>
    </group>
    <group ref="/death_report/covid19_intro">
      <label ref="jr:itext('/death_report/covid19_intro:label')"/>
      <input ref="/death_report/covid19_intro/covid19_intro_note">
        <label ref="jr:itext('/death_report/covid19_intro/covid19_intro_note:label')"/>
      </input>
    </group>
    <group appearance="field-list" ref="/death_report/client_information">
      <label ref="jr:itext('/death_report/client_information:label')"/>
      <input ref="/death_report/client_information/intro_note">
        <label ref="jr:itext('/death_report/client_information/intro_note:label')"/>
      </input>
      <input ref="/death_report/client_information/household_note">
        <label ref="jr:itext('/death_report/client_information/household_note:label')"/>
      </input>
      <input ref="/death_report/client_information/phone_note">
        <label ref="jr:itext('/death_report/client_information/phone_note:label')"/>
      </input>
    </group>
    <group ref="/death_report/death_report_intro">
      <input ref="/death_report/death_report_intro/intro">
        <label ref="jr:itext('/death_report/death_report_intro/intro:label')"/>
      </input>
      <select1 ref="/death_report/death_report_intro/reason_death">
        <label ref="jr:itext('/death_report/death_report_intro/reason_death:label')"/>
        <item>
          <label ref="jr:itext('/death_report/death_report_intro/reason_death/pregnancy_delivery:label')"/>
          <value>pregnancy_delivery</value>
        </item>
        <item>
          <label ref="jr:itext('/death_report/death_report_intro/reason_death/accident:label')"/>
          <value>accident</value>
        </item>
        <item>
          <label ref="jr:itext('/death_report/death_report_intro/reason_death/sickness:label')"/>
          <value>sickness</value>
        </item>
        <item>
          <label ref="jr:itext('/death_report/death_report_intro/reason_death/fever:label')"/>
          <value>fever</value>
        </item>
        <item>
          <label ref="jr:itext('/death_report/death_report_intro/reason_death/other:label')"/>
          <value>other</value>
        </item>
      </select1>
    </group>
    <group appearance="field-list" ref="/death_report/suspected_maternal_death">
      <label ref="jr:itext('/death_report/suspected_maternal_death:label')"/>
      <input ref="/death_report/suspected_maternal_death/date_of_death_maternal">
        <label ref="jr:itext('/death_report/suspected_maternal_death/date_of_death_maternal:label')"/>
      </input>
      <select1 ref="/death_report/suspected_maternal_death/where_death">
        <label ref="jr:itext('/death_report/suspected_maternal_death/where_death:label')"/>
        <item>
          <label ref="jr:itext('/death_report/suspected_maternal_death/where_death/home:label')"/>
          <value>home</value>
        </item>
        <item>
          <label ref="jr:itext('/death_report/suspected_maternal_death/where_death/outside_home:label')"/>
          <value>outside_home</value>
        </item>
        <item>
          <label ref="jr:itext('/death_report/suspected_maternal_death/where_death/tba:label')"/>
          <value>tba</value>
        </item>
        <item>
          <label ref="jr:itext('/death_report/suspected_maternal_death/where_death/health_facility:label')"/>
          <value>health_facility</value>
        </item>
        <item>
          <label ref="jr:itext('/death_report/suspected_maternal_death/where_death/other:label')"/>
          <value>other</value>
        </item>
      </select1>
      <select1 ref="/death_report/suspected_maternal_death/was_pregnant">
        <label ref="jr:itext('/death_report/suspected_maternal_death/was_pregnant:label')"/>
        <item>
          <label ref="jr:itext('/death_report/suspected_maternal_death/was_pregnant/yes:label')"/>
          <value>yes</value>
        </item>
        <item>
          <label ref="jr:itext('/death_report/suspected_maternal_death/was_pregnant/no:label')"/>
          <value>no</value>
        </item>
        <item>
          <label ref="jr:itext('/death_report/suspected_maternal_death/was_pregnant/dont_know:label')"/>
          <value>dont_know</value>
        </item>
      </select1>
      <select1 ref="/death_report/suspected_maternal_death/during_childbirth">
        <label ref="jr:itext('/death_report/suspected_maternal_death/during_childbirth:label')"/>
        <item>
          <label ref="jr:itext('/death_report/suspected_maternal_death/during_childbirth/yes:label')"/>
          <value>yes</value>
        </item>
        <item>
          <label ref="jr:itext('/death_report/suspected_maternal_death/during_childbirth/no:label')"/>
          <value>no</value>
        </item>
      </select1>
      <select1 ref="/death_report/suspected_maternal_death/two_to_three_mo_after_pregnancy_childbirth">
        <label ref="jr:itext('/death_report/suspected_maternal_death/two_to_three_mo_after_pregnancy_childbirth:label')"/>
        <item>
          <label ref="jr:itext('/death_report/suspected_maternal_death/two_to_three_mo_after_pregnancy_childbirth/yes:label')"/>
          <value>yes</value>
        </item>
        <item>
          <label ref="jr:itext('/death_report/suspected_maternal_death/two_to_three_mo_after_pregnancy_childbirth/no:label')"/>
          <value>no</value>
        </item>
      </select1>
    </group>
    <group appearance="field-list" ref="/death_report/next_of_kin">
      <label ref="jr:itext('/death_report/next_of_kin:label')"/>
      <input ref="/death_report/next_of_kin/next_of_kin_name">
        <label ref="jr:itext('/death_report/next_of_kin/next_of_kin_name:label')"/>
      </input>
      <input ref="/death_report/next_of_kin/next_of_kin_rel_w_deceased">
        <label ref="jr:itext('/death_report/next_of_kin/next_of_kin_rel_w_deceased:label')"/>
      </input>
      <input ref="/death_report/next_of_kin/next_of_kin_street_shehia">
        <label ref="jr:itext('/death_report/next_of_kin/next_of_kin_street_shehia:label')"/>
      </input>
      <input ref="/death_report/next_of_kin/next_of_kin_district">
        <label ref="jr:itext('/death_report/next_of_kin/next_of_kin_district:label')"/>
      </input>
      <input appearance="numbers" ref="/death_report/next_of_kin/next_of_kin_phone">
        <label ref="jr:itext('/death_report/next_of_kin/next_of_kin_phone:label')"/>
      </input>
    </group>
    <group appearance="field-list" ref="/death_report/other">
      <input ref="/death_report/other/date_of_death_other">
        <label ref="jr:itext('/death_report/other/date_of_death_other:label')"/>
      </input>
    </group>
  </h:body>
</h:html>
