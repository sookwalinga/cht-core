      <instance id="contact-summary"/>
      <bind nodeset="/community_referral/inputs" relevant="false()"/>
      <bind nodeset="/community_referral/inputs/user/contact_id" type="string"/>
      <bind nodeset="/community_referral/inputs/user/facility_id" type="string"/>
      <bind nodeset="/community_referral/inputs/user/name" type="string"/>
      <bind nodeset="/community_referral/inputs/contact/_id" type="db:person"/>
      <bind nodeset="/community_referral/inputs/contact/name" type="string"/>
      <bind nodeset="/community_referral/inputs/contact/date_of_birth" type="string"/>
      <bind nodeset="/community_referral/client_name" type="string" calculate="../inputs/contact/name"/>
      <bind nodeset="/community_referral/patient_id" type="string" calculate="../inputs/contact/_id"/>
      <bind nodeset="/community_referral/created_by" type="string" calculate="../inputs/user/name"/>
      <bind nodeset="/community_referral/created_by_person_uuid" type="string" calculate="../inputs/user/contact_id"/>
      <bind nodeset="/community_referral/created_by_place_uuid" type="string" calculate="../inputs/user/facility_id"/>
      <bind nodeset="/community_referral/date_of_birth_c" type="string" calculate="../inputs/contact/date_of_birth"/>
      <bind nodeset="/community_referral/age_days" type="string" calculate="int(decimal-date-time(now())-decimal-date-time( /community_referral/date_of_birth_c ))"/>
      <bind nodeset="/community_referral/age_years" type="string" calculate="int( /community_referral/age_days  div (30 *12),0)"/>
      <bind nodeset="/community_referral/start" jr:preload="timestamp" type="dateTime" jr:preloadParams="start"/>
      <bind nodeset="/community_referral/end" jr:preload="timestamp" type="dateTime" jr:preloadParams="end"/>
      <bind nodeset="/community_referral/community_referral/referral_reason" type="select"/>
      <bind nodeset="/community_referral/community_referral/other_referral_reason" type="string" relevant="selected( /community_referral/community_referral/referral_reason ,&quot;other&quot;)"/>
      <bind nodeset="/community_referral/community_referral/referral_type" type="select1" required="true()"/>
      <bind nodeset="/community_referral/community_referral/chw_patient_condition_description" type="string" required="true()"/>
      <bind nodeset="/community_referral/community_referral/has_patient_referral_provided" type="select1" required="true()"/>
      <bind nodeset="/community_referral/community_referral/has_patient_informed_about_referral" type="select1" relevant="selected( /community_referral/community_referral/has_patient_referral_provided ,&quot;yes&quot;)" required="true()"/>
      <bind nodeset="/community_referral/community_referral/patient_consent_for_data_sharing" type="select1"/>
      <bind nodeset="/community_referral/community_referral/has_confidentiality_agreement_confirmed" type="select1" required="true()"/>
      <bind nodeset="/community_referral/community_referral/additional_information_comments" type="string" required="true()"/>
      <bind nodeset="/community_referral/community_referral/confirmation_taken" type="binary" required="true()"/>
      <bind nodeset="/community_referral/household_location/gps_note" readonly="true()" type="string"/>
      <bind nodeset="/community_referral/household_location/gps" type="geopoint" required="true()"/>
      <bind nodeset="/community_referral/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
    </model>
  </h:head>
