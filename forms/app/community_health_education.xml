      <bind nodeset="/community_health_education/distribution_of_pamphlets/note_to_chv_four" readonly="true()" type="string" relevant=" /community_health_education/health_education_delivery/provided_health_education_to_client  = 'yes' and  /community_health_education/distribution_of_pamphlets/distributed_the_pamphlets  = 'yes'"/>
