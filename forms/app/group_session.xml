<?xml version="1.0"?>
<h:html xmlns="http://www.w3.org/2002/xforms" xmlns:h="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms">
  <h:head>
    <h:title>Group Session</h:title>
    <model>
      <itext>
        <translation lang="en">
          <text id="/group_session/group_summary/r_community_meeting_title:label">
            <value>Community Meeting &lt;i class="fa fa-users"&gt;&lt;/i&gt;</value>
          </text>
          <text id="/group_session/group_summary/r_meeting_date:label">
            <value>Meeting happened on **_<output value=" /group_session/group_summary/c_formatted_meeting_date "/>_**</value>
          </text>
          <text id="/group_session/group_summary/r_topics_covered:label">
            <value><output value=" /group_session/meeting_details/topics "/></value>
          </text>
          <text id="/group_session/group_summary/r_topics_covered_title:label">
            <value>Topics Covered &lt;i class="fa fa-info-circle"&gt;&lt;/i&gt;</value>
          </text>
          <text id="/group_session/group_summary:label">
            <value>Summary</value>
          </text>
          <text id="/group_session/inputs/contact/_id:label">
            <value>Place ID</value>
          </text>
          <text id="/group_session/inputs/contact/name:label">
            <value>Place Name</value>
          </text>
          <text id="/group_session/inputs/contact/patient_id:label">
            <value>Patient ID</value>
          </text>
          <text id="/group_session/inputs/contact/place_id:label">
            <value>Medic ID</value>
          </text>
          <text id="/group_session/inputs/patient_id:label">
            <value>Patient ID</value>
          </text>
          <text id="/group_session/inputs/patient_uuid:label">
            <value>Patient UUID</value>
          </text>
          <text id="/group_session/inputs:label">
            <value>Inputs</value>
          </text>
          <text id="/group_session/meeting_details/actions:label">
            <value>What are the actions you have taken to resolve the challenges?</value>
          </text>
          <text id="/group_session/meeting_details/challenges:label">
            <value>What challenges is the CHV experiencing?</value>
          </text>
          <text id="/group_session/meeting_details/meeting_date:jr:constraintMsg">
            <value>Date cannot be a future date</value>
          </text>
          <text id="/group_session/meeting_details/meeting_date:label">
            <value>When was the community meeting?</value>
          </text>
          <text id="/group_session/meeting_details/topics:label">
            <value>What topics were covered during the meeting?</value>
          </text>
          <text id="/group_session/meeting_details:label">
            <value>Meeting Details</value>
          </text>
        </translation>
        <translation lang="sw">
          <text id="/group_session/group_summary/r_community_meeting_title:label">
            <value>Mkutano wa jamii &lt;i class="fa fa-users"&gt;&lt;/i&gt;</value>
          </text>
          <text id="/group_session/group_summary/r_meeting_date:label">
            <value>Mkutano ulifanyika tarehe **_<output value=" /group_session/group_summary/c_formatted_meeting_date "/>_**</value>
          </text>
          <text id="/group_session/group_summary/r_topics_covered:label">
            <value><output value=" /group_session/meeting_details/topics "/></value>
          </text>
          <text id="/group_session/group_summary/r_topics_covered_title:label">
            <value>Mada &lt;i class="fa fa-info-circle"&gt;&lt;/i&gt;</value>
          </text>
          <text id="/group_session/group_summary:label">
            <value>Muhtasari</value>
          </text>
          <text id="/group_session/inputs/contact/_id:label">
            <value>-</value>
          </text>
          <text id="/group_session/inputs/contact/name:label">
            <value>-</value>
          </text>
          <text id="/group_session/inputs/contact/patient_id:label">
            <value>-</value>
          </text>
          <text id="/group_session/inputs/contact/place_id:label">
            <value>-</value>
          </text>
          <text id="/group_session/inputs/patient_id:label">
            <value>-</value>
          </text>
          <text id="/group_session/inputs/patient_uuid:label">
            <value>-</value>
          </text>
          <text id="/group_session/inputs:label">
            <value>-</value>
          </text>
          <text id="/group_session/meeting_details/actions:label">
            <value>Umechukua hatua gani kutatua changamoto za CHV?</value>
          </text>
          <text id="/group_session/meeting_details/challenges:label">
            <value>Ni changamoto zipi ambazo anakutana nazo CHV?</value>
          </text>
          <text id="/group_session/meeting_details/meeting_date:jr:constraintMsg">
            <value>Tafadhali chagua tarehe ya nyuma</value>
          </text>
          <text id="/group_session/meeting_details/meeting_date:label">
            <value>Mkutano wa kikundi ulifanyika lini?</value>
          </text>
          <text id="/group_session/meeting_details/topics:label">
            <value>Ni mambo gani yalizungumziwa wakati wa kikao?</value>
          </text>
          <text id="/group_session/meeting_details:label">
            <value>Taarifa za mkutano</value>
          </text>
        </translation>
      </itext>
      <instance>
        <group_session id="group_session" prefix="J1!group_session!" delimiter="#" version="2022-10-18 11:37:51">
          <inputs>
            <meta>
              <location>
                <lat/>
                <long/>
                <error/>
                <message/>
              </location>
            </meta>
            <source/>
            <source_id/>
            <task_id/>
            <patient_uuid/>
            <patient_id/>
            <contact>
              <_id/>
              <patient_id/>
              <place_id/>
              <name/>
            </contact>
          </inputs>
          <_id/>
          <patient_id/>
          <place_id/>
          <place_name/>
          <meeting_details>
            <meeting_date/>
            <topics/>
            <challenges/>
            <actions/>
          </meeting_details>
          <group_summary>
            <r_community_meeting_title/>
            <c_formatted_meeting_date/>
            <r_meeting_date/>
            <r_topics_covered_title/>
            <r_topics_covered/>
          </group_summary>
          <meta tag="hidden">
            <instanceID/>
            <instanceName/>
          </meta>
        </group_session>
      </instance>
      <instance id="contact-summary"/>
      <bind nodeset="/group_session/inputs" relevant="./source='user'"/>
      <bind nodeset="/group_session/inputs/source" type="string"/>
      <bind nodeset="/group_session/inputs/source_id" type="string"/>
      <bind nodeset="/group_session/inputs/task_id" type="string"/>
      <bind nodeset="/group_session/inputs/patient_uuid" type="string" calculate="../contact/_id"/>
      <bind nodeset="/group_session/inputs/patient_id" type="string" calculate="../contact/patient_id"/>
      <bind nodeset="/group_session/inputs/contact/_id" type="string"/>
      <bind nodeset="/group_session/inputs/contact/patient_id" type="string"/>
      <bind nodeset="/group_session/inputs/contact/place_id" type="string"/>
      <bind nodeset="/group_session/inputs/contact/name" type="string"/>
      <bind nodeset="/group_session/_id" type="string" calculate="../inputs/contact/_id"/>
      <bind nodeset="/group_session/patient_id" type="string" calculate="../inputs/contact/_id"/>
      <bind nodeset="/group_session/place_id" type="string" calculate="../inputs/contact/_id"/>
      <bind nodeset="/group_session/place_name" type="string" calculate="../inputs/contact/name"/>
      <bind nodeset="/group_session/meeting_details/meeting_date" type="date" required="true()" jr:constraintMsg="jr:itext('/group_session/meeting_details/meeting_date:jr:constraintMsg')" constraint=". &lt;= today()"/>
      <bind nodeset="/group_session/meeting_details/topics" type="string" required="true()"/>
      <bind nodeset="/group_session/meeting_details/challenges" type="string" required="true()"/>
      <bind nodeset="/group_session/meeting_details/actions" type="string" required="true()"/>
      <bind nodeset="/group_session/group_summary/r_community_meeting_title" readonly="true()" type="string"/>
      <bind nodeset="/group_session/group_summary/c_formatted_meeting_date" type="string" calculate="format-date( /group_session/meeting_details/meeting_date , '%a %e %b %Y')"/>
      <bind nodeset="/group_session/group_summary/r_meeting_date" readonly="true()" type="string"/>
      <bind nodeset="/group_session/group_summary/r_topics_covered_title" readonly="true()" type="string"/>
      <bind nodeset="/group_session/group_summary/r_topics_covered" readonly="true()" type="string"/>
      <bind nodeset="/group_session/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
      <bind nodeset="/group_session/meta/instanceName" type="string" calculate="D-tree"/>
    </model>
  </h:head>
  <h:body class="pages">
    <group appearance="field-list" ref="/group_session/inputs">
      <label ref="jr:itext('/group_session/inputs:label')"/>
      <group ref="/group_session/inputs/contact">
        <input appearance="select-contact type-health_center" ref="/group_session/inputs/contact/_id">
          <label ref="jr:itext('/group_session/inputs/contact/_id:label')"/>
        </input>
        <input appearance="hidden" ref="/group_session/inputs/contact/patient_id">
          <label ref="jr:itext('/group_session/inputs/contact/patient_id:label')"/>
        </input>
        <input appearance="hidden" ref="/group_session/inputs/contact/place_id">
          <label ref="jr:itext('/group_session/inputs/contact/place_id:label')"/>
        </input>
        <input appearance="hidden" ref="/group_session/inputs/contact/name">
          <label ref="jr:itext('/group_session/inputs/contact/name:label')"/>
        </input>
      </group>
    </group>
    <group appearance="field-list" ref="/group_session/meeting_details">
      <label ref="jr:itext('/group_session/meeting_details:label')"/>
      <input ref="/group_session/meeting_details/meeting_date">
        <label ref="jr:itext('/group_session/meeting_details/meeting_date:label')"/>
      </input>
      <input ref="/group_session/meeting_details/topics">
        <label ref="jr:itext('/group_session/meeting_details/topics:label')"/>
      </input>
      <input ref="/group_session/meeting_details/challenges">
        <label ref="jr:itext('/group_session/meeting_details/challenges:label')"/>
      </input>
      <input ref="/group_session/meeting_details/actions">
        <label ref="jr:itext('/group_session/meeting_details/actions:label')"/>
      </input>
    </group>
    <group appearance="field-list summary" ref="/group_session/group_summary">
      <label ref="jr:itext('/group_session/group_summary:label')"/>
      <input appearance="h2 blue" ref="/group_session/group_summary/r_community_meeting_title">
        <label ref="jr:itext('/group_session/group_summary/r_community_meeting_title:label')"/>
      </input>
      <input ref="/group_session/group_summary/r_meeting_date">
        <label ref="jr:itext('/group_session/group_summary/r_meeting_date:label')"/>
      </input>
      <input appearance="h2 green" ref="/group_session/group_summary/r_topics_covered_title">
        <label ref="jr:itext('/group_session/group_summary/r_topics_covered_title:label')"/>
      </input>
      <input ref="/group_session/group_summary/r_topics_covered">
        <label ref="jr:itext('/group_session/group_summary/r_topics_covered:label')"/>
      </input>
    </group>
  </h:body>
</h:html>
