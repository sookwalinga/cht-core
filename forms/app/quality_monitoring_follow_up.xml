      <bind nodeset="/quality_monitoring_follow_up/group_summary/r_followup" readonly="true()" type="string"/>
      <bind nodeset="/quality_monitoring_follow_up/group_summary/c_formatted_follow_up_date" type="string" calculate="format-date( /quality_monitoring_follow_up/follow_up_details/next_follow_up_date , '%a %e %b %Y')" relevant="selected( /quality_monitoring_follow_up/follow_up_details/follow_up_again , &quot;yes&quot;)"/>
      <bind nodeset="/quality_monitoring_follow_up/group_summary/r_next_follow_up" readonly="true()" type="string" relevant="selected( /quality_monitoring_follow_up/follow_up_details/follow_up_again , &quot;yes&quot;)"/>
      <bind nodeset="/quality_monitoring_follow_up/group_summary/c_formatted_task_date" type="string" calculate="format-date(date(decimal-date-time( /quality_monitoring_follow_up/follow_up_details/next_follow_up_date ) - 2), '%a %e %b %Y')"/>
      <bind nodeset="/quality_monitoring_follow_up/group_summary/r_followup_note" readonly="true()" type="string"/>
      <bind nodeset="/quality_monitoring_follow_up/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
      <bind nodeset="/quality_monitoring_follow_up/meta/instanceName" type="string" calculate="D-tree"/>
