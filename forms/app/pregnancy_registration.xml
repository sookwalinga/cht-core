      </itext>
      <instance>
        <pregnancy_registration delimiter="#" id="pregnancy_registration" prefix="J1!pregnancy_registration!" version="20/06/2019">
          <inputs>
            <meta>
              <location>
                <lat/>
                <long/>
                <error/>
                <message/>
              </location>
            </meta>
            <user>
              <contact_id/>
              <facility_id/>
              <name/>
            </user>
            <contact>
              <date_of_birth/>
            </contact>
          </inputs>
          <age_in_years/>
          <age_below_15>
            <below_15_confirmation/>
          </age_below_15>
          <age_above_49>
            <above_49_confirmation/>
          </age_above_49>
          <pregnancy_form>
            <is_pregnant/>
            <consent/>
            <consent_no/>
            <consent_yes/>
          </pregnancy_form>
          <meta tag="hidden">
            <instanceID/>
          </meta>
        </pregnancy_registration>
      </instance>
      <instance id="contact-summary"/>
      <bind nodeset="/pregnancy_registration/inputs" relevant="false()"/>
      <bind nodeset="/pregnancy_registration/inputs/user/contact_id" type="string"/>
      <bind nodeset="/pregnancy_registration/inputs/user/facility_id" type="string"/>
      <bind nodeset="/pregnancy_registration/inputs/user/name" type="string"/>
      <bind nodeset="/pregnancy_registration/inputs/contact/date_of_birth" type="string"/>
      <bind calculate="(decimal-date-time(today()) - decimal-date-time( /pregnancy_registration/inputs/contact/date_of_birth )) div 365" nodeset="/pregnancy_registration/age_in_years" type="string"/>
      <bind nodeset="/pregnancy_registration/age_below_15/below_15_confirmation" relevant=" /pregnancy_registration/age_in_years  &lt; 15" required="true()" type="select1"/>
      <bind nodeset="/pregnancy_registration/age_above_49/above_49_confirmation" relevant=" /pregnancy_registration/age_in_years  &gt; 49" required="true()" type="select1"/>
      <bind nodeset="/pregnancy_registration/pregnancy_form" relevant="not(selected( /pregnancy_registration/age_below_15/below_15_confirmation ,&quot;no&quot;)) and not(selected( /pregnancy_registration/age_above_49/above_49_confirmation ,&quot;no&quot;))"/>
      <bind nodeset="/pregnancy_registration/pregnancy_form/is_pregnant" required="true()" type="select1"/>
      <bind nodeset="/pregnancy_registration/pregnancy_form/consent" relevant="selected( /pregnancy_registration/pregnancy_form/is_pregnant ,&quot;yes&quot;)" required="true()" type="select1"/>
      <bind nodeset="/pregnancy_registration/pregnancy_form/consent_no" relevant="selected( /pregnancy_registration/pregnancy_form/consent ,&quot;no&quot;)" required="true()" type="select1"/>
      <bind nodeset="/pregnancy_registration/pregnancy_form/consent_yes" readonly="true()" relevant="selected( /pregnancy_registration/pregnancy_form/consent ,&quot;yes&quot;)" type="string"/>
      <bind calculate="concat('uuid:', uuid())" nodeset="/pregnancy_registration/meta/instanceID" readonly="true()" type="string"/>
    </model>
  </h:head>
  <h:body class="pages">
    <group ref="/pregnancy_registration/inputs">
      <group ref="/pregnancy_registration/inputs/user">
        <input ref="/pregnancy_registration/inputs/user/contact_id">
          <label ref="jr:itext('/pregnancy_registration/inputs/user/contact_id:label')"/>
        </input>
        <input ref="/pregnancy_registration/inputs/user/facility_id">
          <label ref="jr:itext('/pregnancy_registration/inputs/user/facility_id:label')"/>
        </input>
        <input ref="/pregnancy_registration/inputs/user/name">
          <label ref="jr:itext('/pregnancy_registration/inputs/user/name:label')"/>
        </input>
      </group>
      <group ref="/pregnancy_registration/inputs/contact">
        <input ref="/pregnancy_registration/inputs/contact/date_of_birth"/>
      </group>
    </group>
    <group appearance="field-list" ref="/pregnancy_registration/age_below_15">
      <select1 ref="/pregnancy_registration/age_below_15/below_15_confirmation">
        <label ref="jr:itext('/pregnancy_registration/age_below_15/below_15_confirmation:label')"/>
        <item>
          <label ref="jr:itext('/pregnancy_registration/age_below_15/below_15_confirmation/yes:label')"/>
          <value>yes</value>
        </item>
        <item>
          <label ref="jr:itext('/pregnancy_registration/age_below_15/below_15_confirmation/no:label')"/>
          <value>no</value>
        </item>
      </select1>
    </group>
    <group appearance="field-list" ref="/pregnancy_registration/age_above_49">
      <select1 ref="/pregnancy_registration/age_above_49/above_49_confirmation">
        <label ref="jr:itext('/pregnancy_registration/age_above_49/above_49_confirmation:label')"/>
        <item>
          <label ref="jr:itext('/pregnancy_registration/age_above_49/above_49_confirmation/yes:label')"/>
          <value>yes</value>
        </item>
        <item>
          <label ref="jr:itext('/pregnancy_registration/age_above_49/above_49_confirmation/no:label')"/>
          <value>no</value>
        </item>
      </select1>
    </group>
    <group appearance="field-list" ref="/pregnancy_registration/pregnancy_form">
      <select1 ref="/pregnancy_registration/pregnancy_form/is_pregnant">
        <label ref="jr:itext('/pregnancy_registration/pregnancy_form/is_pregnant:label')"/>
        <item>
          <label ref="jr:itext('/pregnancy_registration/pregnancy_form/is_pregnant/yes:label')"/>
          <value>yes</value>
        </item>
        <item>
          <label ref="jr:itext('/pregnancy_registration/pregnancy_form/is_pregnant/no:label')"/>
          <value>no</value>
        </item>
      </select1>
      <select1 ref="/pregnancy_registration/pregnancy_form/consent">
        <label ref="jr:itext('/pregnancy_registration/pregnancy_form/consent:label')"/>
        <item>
          <label ref="jr:itext('/pregnancy_registration/pregnancy_form/consent/yes:label')"/>
          <value>yes</value>
        </item>
        <item>
          <label ref="jr:itext('/pregnancy_registration/pregnancy_form/consent/no:label')"/>
          <value>no</value>
        </item>
      </select1>
      <select1 ref="/pregnancy_registration/pregnancy_form/consent_no">
        <label ref="jr:itext('/pregnancy_registration/pregnancy_form/consent_no:label')"/>
        <item>
          <label ref="jr:itext('/pregnancy_registration/pregnancy_form/consent_no/husband_permission:label')"/>
          <value>husband_permission</value>
        </item>
        <item>
          <label ref="jr:itext('/pregnancy_registration/pregnancy_form/consent_no/not_interested:label')"/>
          <value>not_interested</value>
        </item>
      </select1>
      <input ref="/pregnancy_registration/pregnancy_form/consent_yes">
        <label ref="jr:itext('/pregnancy_registration/pregnancy_form/consent_yes:label')"/>
      </input>
    </group>
  </h:body>
</h:html>
