      <bind nodeset="/medication_monitoring/client_gps/client_gps" type="geopoint" required="true()"/>
      <bind nodeset="/medication_monitoring/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
    </model>
