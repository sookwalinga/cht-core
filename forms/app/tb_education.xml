      <bind nodeset="/tb_education/inputs" relevant="false()"/>
      <bind nodeset="/tb_education/inputs/user/contact_id" type="string"/>
      <bind nodeset="/tb_education/inputs/user/facility_id" type="string"/>
      <bind nodeset="/tb_education/inputs/user/name" type="string"/>
      <bind nodeset="/tb_education/inputs/contact/_id" type="db:person"/>
      <bind nodeset="/tb_education/created_by" type="string" calculate="../inputs/user/name"/>
      <bind nodeset="/tb_education/created_by_person_uuid" type="string" calculate="../inputs/user/contact_id"/>
      <bind nodeset="/tb_education/created_by_place_uuid" type="string" calculate="../inputs/user/facility_id"/>
      <bind nodeset="/tb_education/start" jr:preload="timestamp" type="dateTime" jr:preloadParams="start"/>
      <bind nodeset="/tb_education/end" jr:preload="timestamp" type="dateTime" jr:preloadParams="end"/>
      <bind nodeset="/tb_education/tb_introduction/tb_intro" readonly="true()" type="string"/>
      <bind nodeset="/tb_education/tb_meaning/tb_meaning_note" readonly="true()" type="string"/>
      <bind nodeset="/tb_education/tb_causes/tb_causes_note" readonly="true()" type="string"/>
