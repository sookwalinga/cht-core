      <bind nodeset="/tb_education/question_for_chv/note_to_chv" readonly="true()" type="string"/>
      <bind nodeset="/tb_education/question_for_chv/people_reached_note_to_chv" readonly="true()" type="string"/>
      <bind nodeset="/tb_education/question_for_chv/num_people_reached" type="int" constraint=".&gt;= 0 and .&lt;= 100" jr:constraintMsg="jr:itext('/tb_education/question_for_chv/num_people_reached:jr:constraintMsg')" required="true()"/>
      <bind nodeset="/tb_education/question_for_chv/tb_symptoms_note_to_chv" readonly="true()" type="string"/>
      <bind nodeset="/tb_education/question_for_chv/num_people_with_tb" type="int" constraint=".&gt;= 0 and .&lt;=  /tb_education/question_for_chv/num_people_reached " jr:constraintMsg="jr:itext('/tb_education/question_for_chv/num_people_with_tb:jr:constraintMsg')" required="true()"/>
      <bind nodeset="/tb_education/suggestion_for_chv/take_sample_note" readonly="true()" type="string" relevant=" /tb_education/question_for_chv/num_people_with_tb &gt; 0"/>
      <bind nodeset="/tb_education/suggestion_for_chv/submit_form_note" readonly="true()" type="string" relevant=" /tb_education/question_for_chv/num_people_with_tb &gt; 0"/>
      <bind nodeset="/tb_education/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
    </model>
