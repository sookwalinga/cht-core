      <bind nodeset="/chv_challenges_reporting/chv_problem_type/phone_issue/date_problem_happened" type="date" required="true()" relevant="selected( /chv_challenges_reporting/chv_problem_type/phone_issue/phone_problem_type ,&quot;lost_phone&quot;) or selected( /chv_challenges_reporting/chv_problem_type/phone_issue/phone_problem_type ,&quot;stolen_phone&quot;)" jr:constraintMsg="jr:itext('/chv_challenges_reporting/chv_problem_type/phone_issue/date_problem_happened:jr:constraintMsg')" constraint=". &gt;= date('2023-01-01') and . &lt;= today()"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/phone_issue/loss_report_submitted" type="select1" required="true()" relevant="selected( /chv_challenges_reporting/chv_problem_type/phone_issue/phone_problem_type ,&quot;lost_phone&quot;) or selected( /chv_challenges_reporting/chv_problem_type/phone_issue/phone_problem_type ,&quot;stolen_phone&quot;)"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/phone_issue/if_selected_no" readonly="true()" type="string" relevant="selected( /chv_challenges_reporting/chv_problem_type/phone_issue/loss_report_submitted ,&quot;no&quot;) and (selected( /chv_challenges_reporting/chv_problem_type/phone_issue/phone_problem_type ,&quot;lost_phone&quot;) or selected( /chv_challenges_reporting/chv_problem_type/phone_issue/phone_problem_type ,&quot;stolen_phone&quot;))"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/phone_issue/broken_category" type="select" required="true()" relevant="selected( /chv_challenges_reporting/chv_problem_type/phone_issue/phone_problem_type ,&quot;broken_phone&quot;)"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/phone_issue/other" type="string" required="true()" relevant="selected( /chv_challenges_reporting/chv_problem_type/phone_issue/broken_category ,&quot;other&quot;)"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/chv_dropout" relevant="selected( /chv_challenges_reporting/chv_problem_type/problems_type ,&quot;chv_dropout&quot;)"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/chv_dropout/retirement_reason" type="string" required="true()"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/month_claiming" relevant="selected( /chv_challenges_reporting/chv_problem_type/problems_type ,&quot;month_payment_claim&quot;)"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/month_claiming/total_paid" type="int" required="true()" jr:constraintMsg="jr:itext('/chv_challenges_reporting/chv_problem_type/month_claiming/total_paid:jr:constraintMsg')" constraint=". &gt;= 2000 and . &lt;= 50150"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/month_claiming/total_deserved" type="int" required="true()" jr:constraintMsg="jr:itext('/chv_challenges_reporting/chv_problem_type/month_claiming/total_deserved:jr:constraintMsg')" constraint=". &gt;  /chv_challenges_reporting/chv_problem_type/month_claiming/total_paid  and . &lt;= 50150"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/month_claiming/month_claiming_date" type="date" required="true()" jr:constraintMsg="jr:itext('/chv_challenges_reporting/chv_problem_type/month_claiming/month_claiming_date:jr:constraintMsg')" constraint="(. &gt;= today() - 90) and . &lt;= today()"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/month_claiming/problems_description" type="string"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/jna_app_issue" relevant="selected( /chv_challenges_reporting/chv_problem_type/problems_type ,&quot;jna_application&quot;)"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/jna_app_issue/app_issues" type="select" required="true()"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/jna_app_issue/other" type="string" required="true()" relevant="selected( /chv_challenges_reporting/chv_problem_type/jna_app_issue/app_issues ,&quot;other&quot;)"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/other" relevant="selected( /chv_challenges_reporting/chv_problem_type/problems_type ,&quot;other&quot;)"/>
      <bind nodeset="/chv_challenges_reporting/chv_problem_type/other/other_problem_type" type="string" required="true()"/>
      <bind nodeset="/chv_challenges_reporting/meta/instanceID" type="string" readonly="true()" calculate="concat('uuid:', uuid())"/>
    </model>
  </h:head>
