<?xml version="1.0"?>
<h:html xmlns="http://www.w3.org/2002/xforms" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:h="http://www.w3.org/1999/xhtml" xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <h:head>
    <h:title>Equity Survey</h:title>
    <model>
      <instance>
        <equity-survey delimiter="#" id="equity_survey" prefix="J1!equity_survey!" version="2019-03-20 12:34:51">
          <inputs>
            <meta>
              <location>
                <lat/>
                <long/>
                <error/>
                <message/>
              </location>
            </meta>
            <source>user</source>
            <source_id/>
            <contact>
              <_id/>
              <name/>
              <contact>
                <_id/>
                <name/>
              </contact>
              <parent>
                <parent>
                  <contact>
                    <name/>
                    <phone/>
                  </contact>
                </parent>
              </parent>
            </contact>
          </inputs>
          <source/>
          <source_id/>
          <place_id/>
          <place_name/>
          <head/>
          <poverty_assessment>
            <poverty_assessment_note/>
            <drinking_water_source/>
            <latrine_type/>
            <observe_note/>
            <electricity/>
            <floor_material/>
            <floor_material_other/>
            <roof_material/>
            <roof_material_other/>
          </poverty_assessment>
          <group_review>
            <n_submit/>
            <n_household_details_title/>
            <n_household_details/>
            <n_assessment_findings/>
            <n_drinking_water_source/>
            <n_surface_water/>
            <n_uncovered_well_or_spring/>
            <n_vendor_provided/>
            <n_improved_water/>
            <n_latrine_type/>
            <n_unimproved_latrine/>
            <n_shared_latrine/>
            <n_improved_latrine/>
            <n_floor_material/>
            <n_earth/>
            <n_cement/>
            <n_other_floor/>
            <n_roof_material/>
            <n_iron/>
            <n_thatch/>
            <n_other_roof/>
          </group_review>
          <meta tag="hidden">
            <instanceID/>
          </meta>
        </equity-survey>
      </instance>
      <instance id="contact-summary"/>
      <bind nodeset="/equity-survey/inputs" relevant="./source = 'user'"/>
      <bind nodeset="/equity-survey/inputs/source" type="string"/>
      <bind nodeset="/equity-survey/inputs/source_id" type="string"/>
      <bind nodeset="/equity-survey/inputs/contact/_id" type="db:clinic"/>
      <bind nodeset="/equity-survey/inputs/contact/name" type="string"/>
      <bind nodeset="/equity-survey/inputs/contact/contact/_id" type="db:person"/>
      <bind nodeset="/equity-survey/inputs/contact/contact/name" type="string"/>
      <bind nodeset="/equity-survey/inputs/contact/parent/parent/contact/name" type="string"/>
      <bind nodeset="/equity-survey/inputs/contact/parent/parent/contact/phone" type="string"/>
      <bind calculate="../inputs/source" nodeset="/equity-survey/source" type="string"/>
      <bind calculate="../inputs/source_id" nodeset="/equity-survey/source_id" type="string"/>
      <bind calculate="../inputs/contact/_id" nodeset="/equity-survey/place_id" type="string"/>
      <bind calculate="../inputs/contact/name" nodeset="/equity-survey/place_name" type="string"/>
      <bind calculate="../inputs/contact/contact/name" nodeset="/equity-survey/head" type="string"/>
      <bind nodeset="/equity-survey/poverty_assessment/poverty_assessment_note" readonly="true()" type="string"/>
      <bind nodeset="/equity-survey/poverty_assessment/drinking_water_source" required="true()" type="select"/>
      <bind nodeset="/equity-survey/poverty_assessment/latrine_type" required="true()" type="select1"/>
      <bind nodeset="/equity-survey/poverty_assessment/observe_note" readonly="true()" type="string"/>
      <bind nodeset="/equity-survey/poverty_assessment/electricity" required="true()" type="select1"/>
      <bind nodeset="/equity-survey/poverty_assessment/floor_material" required="true()" type="select1"/>
      <bind nodeset="/equity-survey/poverty_assessment/floor_material_other" relevant="selected(../floor_material,'other')" required="true()" type="string"/>
      <bind nodeset="/equity-survey/poverty_assessment/roof_material" required="true()" type="select1"/>
      <bind nodeset="/equity-survey/poverty_assessment/roof_material_other" relevant="selected(../roof_material,'other')" required="true()" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_submit" readonly="true()" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_household_details_title" readonly="true()" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_household_details" readonly="true()" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_assessment_findings" readonly="true()" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_drinking_water_source" readonly="true()" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_surface_water" readonly="true()" relevant="selected(../../poverty_assessment/drinking_water_source, 'surface_water')" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_uncovered_well_or_spring" readonly="true()" relevant="selected(../../poverty_assessment/drinking_water_source, 'uncovered_well_or_spring')" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_vendor_provided" readonly="true()" relevant="selected(../../poverty_assessment/drinking_water_source, 'vendor_provided')" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_improved_water" readonly="true()" relevant="selected(../../poverty_assessment/drinking_water_source, 'improved')" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_latrine_type" readonly="true()" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_unimproved_latrine" readonly="true()" relevant="selected(../../poverty_assessment/latrine_type, 'unimproved')" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_shared_latrine" readonly="true()" relevant="selected(../../poverty_assessment/latrine_type, 'shared')" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_improved_latrine" readonly="true()" relevant="selected(../../poverty_assessment/latrine_type, 'improved')" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_floor_material" readonly="true()" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_earth" readonly="true()" relevant="selected(../../poverty_assessment/floor_material, 'earth')" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_cement" readonly="true()" relevant="selected(../../poverty_assessment/floor_material, 'cement')" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_other_floor" readonly="true()" relevant="selected(../../poverty_assessment/floor_material, 'other')" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_roof_material" readonly="true()" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_iron" readonly="true()" relevant="selected(../../poverty_assessment/roof_material, 'iron')" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_thatch" readonly="true()" relevant="selected(../../poverty_assessment/roof_material, 'thatch')" type="string"/>
      <bind nodeset="/equity-survey/group_review/n_other_roof" readonly="true()" relevant="selected(../../poverty_assessment/roof_material, 'other')" type="string"/>
      <bind calculate="concat('uuid:', uuid())" nodeset="/equity-survey/meta/instanceID" readonly="true()" type="string"/>
    </model>
  </h:head>
  <h:body class="pages">
    <group appearance="field-list" ref="/equity-survey/inputs">
      <label>Patient</label>
      <group ref="/equity-survey/inputs/contact">
        <label>Contact</label>
        <input appearance="db-object" ref="/equity-survey/inputs/contact/_id">
          <label>What is the patient's name?</label>
        </input>
        <group ref="/equity-survey/inputs/contact/contact">
          <label>Contact</label>
          <input appearance="db-object" ref="/equity-survey/inputs/contact/contact/_id">
            <label>ID of head of household</label>
          </input>
        </group>
        <group ref="/equity-survey/inputs/contact/parent">
          <label>Parent</label>
          <group ref="/equity-survey/inputs/contact/parent/parent">
            <label>Parent</label>
            <group ref="/equity-survey/inputs/contact/parent/parent/contact">
              <label>Contact</label>
            </group>
          </group>
        </group>
      </group>
    </group>
    <group appearance="field-list" ref="/equity-survey/poverty_assessment">
      <label>Poverty Assessment</label>
      <input ref="/equity-survey/poverty_assessment/poverty_assessment_note">
        <label>&lt;span style="color:green;"&gt;**SAY: Now I'm going to ask a few more questions about you and your family.**&lt;/span&gt;</label>
      </input>
      <select ref="/equity-survey/poverty_assessment/drinking_water_source">
        <label>ASK: From where do you usually get your drinking water?</label>
        <item>
          <label>Surface water (river, pond, dam, stream, lake)</label>
          <value>surface_water</value>
        </item>
        <item>
          <label>Uncovered well or spring</label>
          <value>uncovered_well_or_spring</value>
        </item>
        <item>
          <label>Vendor provided (cart or truck) or bottled</label>
          <value>vendor_provided</value>
        </item>
        <item>
          <label>Piped water, protected well, rainwater</label>
          <value>improved</value>
        </item>
      </select>
      <select1 ref="/equity-survey/poverty_assessment/latrine_type">
        <label>ASK: What type of latrine does your household typically use?</label>
        <item>
          <label>Unimproved facility (open defecation, disposal with other forms of solid waste, pit latrine without slab/platform, open pit, hanging latrine, bucket latrine)</label>
          <value>unimproved</value>
        </item>
        <item>
          <label>Shared facility (any facility shared with more than one household)</label>
          <value>shared</value>
        </item>
        <item>
          <label>Improved facilities (sewer connections, septic system connections, pour-flush latrines, ventilated improved pit latrines and pit latrines with a slab or covered pit)</label>
          <value>improved</value>
        </item>
      </select1>
      <input ref="/equity-survey/poverty_assessment/observe_note">
        <label>&lt;span style="color:green;"&gt;**For the next set of questions, observe the household but do not directly ask to the household member.**&lt;/span&gt;</label>
      </input>
      <select1 ref="/equity-survey/poverty_assessment/electricity">
        <label>OBSERVE: Does the household have electricity?</label>
        <item>
          <label>Yes</label>
          <value>yes</value>
        </item>
        <item>
          <label>No</label>
          <value>no</value>
        </item>
      </select1>
      <select1 ref="/equity-survey/poverty_assessment/floor_material">
        <label>OBSERVE: What is the main material of the floor of the dwelling?</label>
        <item>
          <label>Earth/sand/dung</label>
          <value>earth</value>
        </item>
        <item>
          <label>Cement/concrete/tiles</label>
          <value>cement</value>
        </item>
        <item>
          <label>Other</label>
          <value>other</value>
        </item>
      </select1>
      <input ref="/equity-survey/poverty_assessment/floor_material_other">
        <label>Enter floor material:</label>
      </input>
      <select1 ref="/equity-survey/poverty_assessment/roof_material">
        <label>OBSERVE: What is the main material of the roof of the dwelling?</label>
        <item>
          <label>Iron sheet</label>
          <value>iron</value>
        </item>
        <item>
          <label>Grass/thatch/palm leaf/mud</label>
          <value>thatch</value>
        </item>
        <item>
          <label>Other</label>
          <value>other</value>
        </item>
      </select1>
      <input ref="/equity-survey/poverty_assessment/roof_material_other">
        <label>Enter roof material:</label>
      </input>
    </group>
    <group appearance="field-list summary" ref="/equity-survey/group_review">
      <label>Summary page</label>
      <input ref="/equity-survey/group_review/n_submit">
        <label>_Be sure you submit to complete this action._</label>
      </input>
      <input appearance="h1 yellow" ref="/equity-survey/group_review/n_household_details_title">
        <label>Household details&lt;I class="fa fa-user"&gt;&lt;/i&gt;</label>
      </input>
      <input ref="/equity-survey/group_review/n_household_details">
        <label>&lt;h4 style=&quot;text-align:center;&quot;&gt;<output value=" /equity-survey/place_name "/> <output value=" /equity-survey/head "/>&lt;/h4&gt;</label>
      </input>
      <input appearance="h1 blue" ref="/equity-survey/group_review/n_assessment_findings">
        <label>Assessment findings&lt;I class="fa fa-user"&gt;&lt;/i&gt;</label>
      </input>
      <input ref="/equity-survey/group_review/n_drinking_water_source">
        <label>**_Drinking water source_**</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_surface_water">
        <label>_Surface water (river, pond, dam, stream, lake)_</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_uncovered_well_or_spring">
        <label>_Uncovered well or spring_</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_vendor_provided">
        <label>_Vendor provided (cart or truck) or bottled_</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_improved_water">
        <label>_Piped water, protected well, rainwater_</label>
      </input>
      <input ref="/equity-survey/group_review/n_latrine_type">
        <label>**_Type of latrine_**</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_unimproved_latrine">
        <label>_Unimproved facility (open defecation, disposal with other forms of solid waste, pit latrine without slab/platform, open pit, hanging latrine, bucket latrine)_</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_shared_latrine">
        <label>_Shared facility (any facility shared with more than one household)_</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_improved_latrine">
        <label>_Improved facilities (sewer connections, septic system connections, pour-flush latrines, ventilated improved pit latrines and pit latrines with a slab or covered pit)_</label>
      </input>
      <input ref="/equity-survey/group_review/n_floor_material">
        <label>**_Main floor material_**</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_earth">
        <label>Earth/sand/dung</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_cement">
        <label>Cement/concrete/tiles</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_other_floor">
        <label><output value=" /equity-survey/poverty_assessment/floor_material_other "/></label>
      </input>
      <input ref="/equity-survey/group_review/n_roof_material">
        <label>**_Main roofing material_**</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_iron">
        <label>Iron</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_thatch">
        <label>Thatch</label>
      </input>
      <input appearance="li" ref="/equity-survey/group_review/n_other_roof">
        <label><output value=" /equity-survey/poverty_assessment/roof_material_other "/></label>
      </input>
    </group>
  </h:body>
</h:html>
