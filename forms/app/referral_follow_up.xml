      <instance id="contact-summary"/>
      <bind nodeset="/referral_follow_up/inputs/last_visit_date" type="string"/>
      <bind nodeset="/referral_follow_up/inputs/referral_reasons" type="string"/>
      <bind nodeset="/referral_follow_up/inputs/user/contact_id" type="string"/>
      <bind nodeset="/referral_follow_up/inputs/user/facility_id" type="string"/>
      <bind nodeset="/referral_follow_up/inputs/user/name" type="string"/>
      <bind nodeset="/referral_follow_up/inputs/contact/_id" type="db:person"/>
      <bind nodeset="/referral_follow_up/inputs/contact/name" type="string"/>
      <bind nodeset="/referral_follow_up/inputs/contact/sex" type="string"/>
      <bind nodeset="/referral_follow_up/inputs/contact/date_of_birth" type="string"/>
      <bind calculate="../inputs/contact/_id" nodeset="/referral_follow_up/client" type="string"/>
      <bind calculate="../inputs/contact/name" nodeset="/referral_follow_up/client_name" type="string"/>
      <bind calculate="../inputs/last_visit_date" nodeset="/referral_follow_up/last_visit" type="string"/>
      <bind calculate="../inputs/reasons" nodeset="/referral_follow_up/reasons" type="string"/>
      <bind nodeset="/referral_follow_up/referral_follow_up/intro" readonly="true()" type="string"/>
      <bind nodeset="/referral_follow_up/referral_follow_up/went_to_facility" required="true()" type="select1"/>
      <bind nodeset="/referral_follow_up/referral_follow_up/congratulate" readonly="true()" relevant="selected( /referral_follow_up/referral_follow_up/went_to_facility ,&quot;yes&quot;)" type="string"/>
      <bind nodeset="/referral_follow_up/referral_follow_up/got_services" relevant="selected( /referral_follow_up/referral_follow_up/went_to_facility ,&quot;yes&quot;)" required="true()" type="select1"/>
      <bind nodeset="/referral_follow_up/referral_follow_up/reasons_no_services" readonly="true()" relevant="selected( /referral_follow_up/referral_follow_up/went_to_facility ,&quot;yes&quot;) and selected( /referral_follow_up/referral_follow_up/got_services ,&quot;no&quot;)" type="string"/>
      <bind nodeset="/referral_follow_up/referral_follow_up/did_not_go" relevant="selected( /referral_follow_up/referral_follow_up/went_to_facility ,&quot;no&quot;)"/>
      <bind nodeset="/referral_follow_up/referral_follow_up/did_not_go/reason_didnt_go" required="true()" type="select"/>
      <bind nodeset="/referral_follow_up/referral_follow_up/did_not_go/discuss_reasons" readonly="true()" type="string"/>
      <bind nodeset="/referral_follow_up/referral_follow_up/did_not_go/complete_referral" required="true()" type="select1"/>
      <bind nodeset="/referral_follow_up/referral_follow_up/did_not_go/next_follow_up" readonly="true()" relevant="selected( /referral_follow_up/referral_follow_up/did_not_go/complete_referral ,&quot;yes&quot;)" type="string"/>
      <bind calculate="concat('uuid:', uuid())" nodeset="/referral_follow_up/meta/instanceID" readonly="true()" type="string"/>
    </model>
  </h:head>
  <h:body>
    <group appearance="hidden" ref="/referral_follow_up/inputs">
      <input ref="/referral_follow_up/inputs/last_visit_date"/>
      <input ref="/referral_follow_up/inputs/referral_reasons"/>
      <group ref="/referral_follow_up/inputs/user">
        <input ref="/referral_follow_up/inputs/user/contact_id">
          <label ref="jr:itext('/referral_follow_up/inputs/user/contact_id:label')"/>
        </input>
        <input ref="/referral_follow_up/inputs/user/facility_id">
          <label ref="jr:itext('/referral_follow_up/inputs/user/facility_id:label')"/>
        </input>
        <input ref="/referral_follow_up/inputs/user/name">
          <label ref="jr:itext('/referral_follow_up/inputs/user/name:label')"/>
        </input>
      </group>
      <group ref="/referral_follow_up/inputs/contact">
        <input appearance="db-object" ref="/referral_follow_up/inputs/contact/_id"/>
        <input ref="/referral_follow_up/inputs/contact/name"/>
        <input ref="/referral_follow_up/inputs/contact/sex"/>
        <input ref="/referral_follow_up/inputs/contact/date_of_birth"/>
      </group>
    </group>
    <group ref="/referral_follow_up/referral_follow_up">
      <label ref="jr:itext('/referral_follow_up/referral_follow_up:label')"/>
      <input ref="/referral_follow_up/referral_follow_up/intro">
        <label ref="jr:itext('/referral_follow_up/referral_follow_up/intro:label')"/>
      </input>
      <select1 ref="/referral_follow_up/referral_follow_up/went_to_facility">
        <label ref="jr:itext('/referral_follow_up/referral_follow_up/went_to_facility:label')"/>
        <item>
          <label ref="jr:itext('/referral_follow_up/referral_follow_up/went_to_facility/yes:label')"/>
          <value>yes</value>
        </item>
        <item>
          <label ref="jr:itext('/referral_follow_up/referral_follow_up/went_to_facility/no:label')"/>
          <value>no</value>
        </item>
      </select1>
      <input ref="/referral_follow_up/referral_follow_up/congratulate">
        <label ref="jr:itext('/referral_follow_up/referral_follow_up/congratulate:label')"/>
      </input>
      <select1 ref="/referral_follow_up/referral_follow_up/got_services">
        <label ref="jr:itext('/referral_follow_up/referral_follow_up/got_services:label')"/>
        <item>
          <label ref="jr:itext('/referral_follow_up/referral_follow_up/got_services/yes:label')"/>
          <value>yes</value>
        </item>
        <item>
          <label ref="jr:itext('/referral_follow_up/referral_follow_up/got_services/no:label')"/>
          <value>no</value>
        </item>
      </select1>
      <input ref="/referral_follow_up/referral_follow_up/reasons_no_services">
        <label ref="jr:itext('/referral_follow_up/referral_follow_up/reasons_no_services:label')"/>
      </input>
      <group ref="/referral_follow_up/referral_follow_up/did_not_go">
        <select ref="/referral_follow_up/referral_follow_up/did_not_go/reason_didnt_go">
          <label ref="jr:itext('/referral_follow_up/referral_follow_up/did_not_go/reason_didnt_go:label')"/>
          <item>
            <label ref="jr:itext('/referral_follow_up/referral_follow_up/did_not_go/reason_didnt_go/no_money:label')"/>
            <value>no_money</value>
          </item>
          <item>
            <label ref="jr:itext('/referral_follow_up/referral_follow_up/did_not_go/reason_didnt_go/did_not_want:label')"/>
            <value>did_not_want</value>
          </item>
          <item>
            <label ref="jr:itext('/referral_follow_up/referral_follow_up/did_not_go/reason_didnt_go/no_permission:label')"/>
            <value>no_permission</value>
          </item>
          <item>
            <label ref="jr:itext('/referral_follow_up/referral_follow_up/did_not_go/reason_didnt_go/other:label')"/>
            <value>other</value>
          </item>
        </select>
        <input ref="/referral_follow_up/referral_follow_up/did_not_go/discuss_reasons">
          <label ref="jr:itext('/referral_follow_up/referral_follow_up/did_not_go/discuss_reasons:label')"/>
        </input>
        <select1 ref="/referral_follow_up/referral_follow_up/did_not_go/complete_referral">
          <label ref="jr:itext('/referral_follow_up/referral_follow_up/did_not_go/complete_referral:label')"/>
          <item>
            <label ref="jr:itext('/referral_follow_up/referral_follow_up/did_not_go/complete_referral/yes:label')"/>
            <value>yes</value>
          </item>
          <item>
            <label ref="jr:itext('/referral_follow_up/referral_follow_up/did_not_go/complete_referral/no:label')"/>
            <value>no</value>
          </item>
        </select1>
        <input ref="/referral_follow_up/referral_follow_up/did_not_go/next_follow_up">
          <label ref="jr:itext('/referral_follow_up/referral_follow_up/did_not_go/next_follow_up:label')"/>
        </input>
      </group>
    </group>
  </h:body>
</h:html>
