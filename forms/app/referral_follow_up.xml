            <value>No</value>
          </text>
          <text id="/referral_follow_up/referral_follow_up/got_services/yes:label">
            <value>Yes</value>
          </text>
          <text id="/referral_follow_up/referral_follow_up/got_services:label">
            <value>ASK: Did you get the services?</value>
          </text>
          <text id="/referral_follow_up/referral_follow_up/intro:label">
            <value>SAY: I'm coming to check up on you. On my visit on {last_visit_date}, I gave you a referral to the health facility for the following reasons:
{referral_reasons}</value>
          </text>
          <text id="/referral_follow_up/referral_follow_up/reasons_no_services:label">
            <value>Discuss the reasons, and try to solve the problems and plan for the referral completion.</value>
          </text>
          <text id="/referral_follow_up/referral_follow_up/went_to_facility/no:label">
            <value>No</value>
          </text>
          <text id="/referral_follow_up/referral_follow_up/went_to_facility/yes:label">
            <value>Yes</value>
          </text>
          <text id="/referral_follow_up/referral_follow_up/went_to_facility:label">
            <value>AKS: Did you go to the health facility?</value>
          </text>
          <text id="/referral_follow_up/referral_follow_up:label">
            <value>Referral follow-up</value>
          </text>
