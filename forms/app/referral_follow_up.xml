    <model>
      <itext>
        <translation lang="en">
          <text id="/referral_follow_up/inputs/user/contact_id:label">
            <value>Contact ID of the logged in user</value>
          </text>
          <text id="/referral_follow_up/inputs/user/facility_id:label">
