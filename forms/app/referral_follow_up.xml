      <instance>
        <referral_follow_up delimiter="#" id="referral_follow_up" prefix="J1!referral_follow_up!" version="2019-04-29 00:00:00">
          <inputs>
            <meta>
              <location>
                <lat/>
                <long/>
                <error/>
                <message/>
              </location>
            </meta>
            <last_visit_date/>
            <referral_reasons/>
            <user>
              <contact_id/>
              <facility_id/>
              <name/>
            </user>
            <contact>
              <_id/>
              <name/>
              <sex/>
              <date_of_birth/>
